rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
  
    function isAdmin() {
      return request.auth != null && request.auth.token.email in ['admin@myschool.com', 'kartikthorat2431@gmail.com'];
    }

    match /teachers/{userId} {
      allow read: if request.auth != null && (isAdmin() || request.auth.uid == userId);
      allow write: if request.auth != null && (isAdmin() || request.auth.uid == userId);
    }

    match /admin_settings/{docId} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }
    
    match /global_subjects/{docId} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }

    match /class_default_subjects/{docId} {
      allow read: if request.auth != null;
      allow wrchite: if isAdmin();
    }

    match /subscriptions/{docId} {
      allow read: if request.auth != null && (isAdmin() || resource.data.teacherId == request.auth.uid);
      allow create: if request.auth != null && request.resource.data.teacherId == request.auth.uid;
      allow update, delete: if isAdmin();
    }
    
    match /remarkBanks/{docId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    match /transfer_requests/{docId} {
      allow create: if request.auth != null && request.resource.data.fromTeacherId == request.auth.uid;
      allow read: if request.auth != null;
      allow update: if request.auth != null;
    }

    // Helper function to check if the user is the owner of the student record
    function isStudentOwner(studentId) {
      return request.auth != null &&
        exists(/databases/$(database)/documents/students/$(studentId)) &&
        get(/databases/$(database)/documents/students/$(studentId)).data.teacherId == request.auth.uid;
    }

    // Helper function to check if the user is a linked parent of the student
    function isParentOf(studentId) {
      return request.auth != null &&
        exists(/databases/$(database)/documents/parent_links/$(studentId)) &&
        get(/databases/$(database)/documents/parent_links/$(studentId)).data.parentUid == request.auth.uid;
    }

    // Explicit override rules for parent portal collections
    match /parent_links/{studentId} {
      allow read: if request.auth != null && (
        isStudentOwner(studentId) ||
        resource == null ||
        !('parentUid' in resource.data) ||
        resource.data.parentUid == null ||
        resource.data.parentUid == request.auth.uid ||
        resource.data.teacherId == request.auth.uid
      );
      allow create: if request.auth != null && (
        isAdmin() ||
        isStudentOwner(studentId) ||
        request.resource.data.teacherId == request.auth.uid
      );
      allow update: if request.auth != null && (
        isAdmin() ||
        isStudentOwner(studentId) ||
        (
          (resource.data.parentUid == null || !('parentUid' in resource.data)) &&
          request.resource.data.parentUid == request.auth.uid
        )
      );
      allow delete: if request.auth != null && (
        isAdmin() ||
        isStudentOwner(studentId)
      );
    }

    match /students/{studentId} {
      allow read: if request.auth != null && (
        isAdmin() ||
        resource.data.teacherId == request.auth.uid ||
        isParentOf(studentId)
      );
    }

    match /marks/{markId} {
      allow read: if request.auth != null && (
        isAdmin() ||
        resource.data.teacherId == request.auth.uid ||
        isParentOf(resource.data.studentId)
      );
    }

    match /schools/{schoolId} {
      allow read: if request.auth != null;
    }

    match /classes/{classId} {
      allow read: if request.auth != null;
    }

    // Rules for teacher-owned collections
    match /{collection}/{docId} {
      allow read: if request.auth != null && (
        isAdmin() ||
        (collection in ['schools', 'academic_years', 'semesters', 'classes', 'students', 'marks', 'attendance_records'] && resource.data.teacherId == request.auth.uid)
      );
      allow create: if request.auth != null && (
        isAdmin() ||
        (collection in ['schools', 'academic_years', 'semesters', 'classes', 'students', 'marks', 'attendance_records'] && request.resource.data.teacherId == request.auth.uid)
      );
      allow update: if request.auth != null && (
        isAdmin() ||
        (collection in ['schools', 'academic_years', 'semesters', 'classes', 'students', 'marks', 'attendance_records'] && 
          (!('teacherId' in resource.data) || resource.data.teacherId == request.auth.uid) && 
          request.resource.data.teacherId == request.auth.uid)
      );
      allow delete: if request.auth != null && (
        isAdmin() ||
        (collection in ['schools', 'academic_years', 'semesters', 'classes', 'students', 'marks', 'attendance_records'] && 
          (!('teacherId' in resource.data) || resource.data.teacherId == request.auth.uid))
      );
    }
  }
}
