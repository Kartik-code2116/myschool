<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Typography - Display -->
    <style name="TextAppearance.EduReport.DisplayLarge" parent="TextAppearance.Material3.DisplayLarge">
        <item name="android:textColor">@color/on_surface</item>
    </style>

    <style name="TextAppearance.EduReport.DisplayMedium" parent="TextAppearance.Material3.DisplayMedium">
        <item name="android:textColor">@color/on_surface</item>
    </style>

    <style name="TextAppearance.EduReport.DisplaySmall" parent="TextAppearance.Material3.DisplaySmall">
        <item name="android:textColor">@color/on_surface</item>
    </style>

    <!-- Typography - Headline -->
    <style name="TextAppearance.EduReport.HeadlineLarge" parent="TextAppearance.Material3.HeadlineLarge">
        <item name="android:textColor">@color/on_surface</item>
    </style>

    <style name="TextAppearance.EduReport.HeadlineMedium" parent="TextAppearance.Material3.HeadlineMedium">
        <item name="android:textColor">@color/on_surface</item>
    </style>

    <style name="TextAppearance.EduReport.HeadlineSmall" parent="TextAppearance.Material3.HeadlineSmall">
        <item name="android:textColor">@color/on_surface</item>
    </style>

    <!-- Typography - Title -->
    <style name="TextAppearance.EduReport.TitleLarge" parent="TextAppearance.Material3.TitleLarge">
        <item name="android:textColor">@color/on_surface</item>
    </style>

    <style name="TextAppearance.EduReport.TitleMedium" parent="TextAppearance.Material3.TitleMedium">
        <item name="android:textColor">@color/on_surface</item>
    </style>

    <style name="TextAppearance.EduReport.TitleSmall" parent="TextAppearance.Material3.TitleSmall">
        <item name="android:textColor">@color/on_surface</item>
    </style>

    <!-- Typography - Body -->
    <style name="TextAppearance.EduReport.BodyLarge" parent="TextAppearance.Material3.BodyLarge">
        <item name="android:textColor">@color/on_surface</item>
    </style>

    <style name="TextAppearance.EduReport.BodyMedium" parent="TextAppearance.Material3.BodyMedium">
        <item name="android:textColor">@color/on_surface</item>
    </style>

    <style name="TextAppearance.EduReport.BodySmall" parent="TextAppearance.Material3.BodySmall">
        <item name="android:textColor">@color/on_surface_variant</item>
    </style>

    <!-- Typography - Label -->
    <style name="TextAppearance.EduReport.LabelLarge" parent="TextAppearance.Material3.LabelLarge">
        <item name="android:textColor">@color/on_surface</item>
    </style>

    <style name="TextAppearance.EduReport.LabelMedium" parent="TextAppearance.Material3.LabelMedium">
        <item name="android:textColor">@color/on_surface_variant</item>
    </style>

    <style name="TextAppearance.EduReport.LabelSmall" parent="TextAppearance.Material3.LabelSmall">
        <item name="android:textColor">@color/on_surface_variant</item>
    </style>

    <!-- Button Styles -->
    <style name="Widget.EduReport.Button" parent="Widget.Material3.Button">
        <item name="android:textAppearance">@style/TextAppearance.EduReport.LabelLarge</item>
        <item name="cornerRadius">12dp</item>
        <item name="android:minHeight">56dp</item>
        <item name="android:paddingStart">24dp</item>
        <item name="android:paddingEnd">24dp</item>
        <item name="elevation">2dp</item>
    </style>

    <style name="Widget.EduReport.Button.Secondary">
        <item name="backgroundTint">@color/secondary</item>
    </style>

    <style name="Widget.EduReport.Button.Outlined" parent="Widget.Material3.Button.OutlinedButton">
        <item name="android:textAppearance">@style/TextAppearance.EduReport.LabelLarge</item>
        <item name="cornerRadius">12dp</item>
        <item name="android:minHeight">56dp</item>
        <item name="strokeColor">@color/primary</item>
        <item name="strokeWidth">2dp</item>
    </style>

    <style name="Widget.EduReport.Button.Tonal" parent="Widget.Material3.Button.TonalButton">
        <item name="android:textAppearance">@style/TextAppearance.EduReport.LabelLarge</item>
        <item name="cornerRadius">12dp</item>
        <item name="android:minHeight">56dp</item>
    </style>

    <!-- Card Styles -->
    <style name="Widget.EduReport.CardView" parent="Widget.Material3.CardView.Elevated">
        <item name="cardCornerRadius">16dp</item>
        <item name="cardElevation">4dp</item>
        <item name="contentPadding">16dp</item>
        <item name="cardBackgroundColor">@color/surface</item>
    </style>

    <style name="Widget.EduReport.CardView.Filled" parent="Widget.Material3.CardView.Filled">
        <item name="cardCornerRadius">16dp</item>
        <item name="contentPadding">16dp</item>
        <item name="cardBackgroundColor">@color/surface_variant</item>
    </style>

    <!-- Extended FAB Style -->
    <style name="Widget.EduReport.ExtendedFloatingActionButton" parent="Widget.Material3.ExtendedFloatingActionButton.Primary">
        <item name="cornerRadius">16dp</item>
        <item name="android:minHeight">56dp</item>
        <item name="iconSize">24dp</item>
    </style>

    <!-- Image View Style for Scanner -->
    <style name="Widget.EduReport.ScannerImage" parent="">
        <item name="cornerRadius">24dp</item>
        <item name="strokeColor">@color/scanner_frame</item>
        <item name="strokeWidth">4dp</item>
    </style>

    <!-- Progress Bar Style -->
    <style name="Widget.EduReport.CircularProgress" parent="Widget.Material3.CircularProgressIndicator">
        <item name="indicatorColor">@color/primary</item>
        <item name="trackColor">@color/primary_container</item>
        <item name="indicatorSize">48dp</item>
        <item name="trackThickness">4dp</item>
    </style>

    <!-- Chip Styles -->
    <style name="Widget.EduReport.Chip" parent="Widget.Material3.Chip.Assist">
        <item name="chipBackgroundColor">@color/primary_container</item>
        <item name="android:textColor">@color/on_primary_container</item>
        <item name="chipStrokeWidth">0dp</item>
    </style>

    <!-- Text Input Style -->
    <style name="Widget.EduReport.TextInputLayout" parent="Widget.Material3.TextInputLayout.OutlinedBox">
        <item name="boxCornerRadiusTopStart">12dp</item>
        <item name="boxCornerRadiusTopEnd">12dp</item>
        <item name="boxCornerRadiusBottomStart">12dp</item>
        <item name="boxCornerRadiusBottomEnd">12dp</item>
        <item name="boxStrokeColor">@color/primary</item>
        <item name="hintTextColor">@color/primary</item>
    </style>

    <!-- Attendance Table Styles -->
    <style name="AttendanceHeaderCell">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_weight">1</item>
        <item name="android:gravity">center</item>
        <item name="android:textSize">9sp</item>
        <item name="android:textColor">?attr/colorPrimary</item>
        <item name="android:textStyle">bold</item>
        <item name="android:paddingTop">4dp</item>
        <item name="android:paddingBottom">4dp</item>
        <item name="android:singleLine">true</item>
    </style>

    <style name="AttendanceValueCell">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_weight">1</item>
        <item name="android:gravity">center</item>
        <item name="android:textSize">9sp</item>
        <item name="android:textColor">?attr/colorOnSurface</item>
        <item name="android:paddingTop">6dp</item>
        <item name="android:paddingBottom">6dp</item>
        <item name="android:singleLine">true</item>
    </style>

    <style name="AttendanceDivider">
        <item name="android:layout_width">1dp</item>
        <item name="android:layout_height">match_parent</item>
        <item name="android:background">?attr/colorOutlineVariant</item>
    </style>

    <!-- Navigation Drawer Custom Styling -->
    <style name="Widget.EduReport.NavigationView" parent="Widget.Material3.NavigationView">
        <item name="android:background">@drawable/bg_drawer_rounded</item>
        <item name="backgroundTint">@null</item>
        <item name="itemIconTint">?attr/colorOnSurfaceVariant</item>
        <item name="itemTextColor">?attr/colorOnSurface</item>
        <item name="itemIconSize">24dp</item>
        <item name="itemMinHeight">52dp</item>
        <item name="itemMaxLines">1</item>
        <item name="itemTextAppearance">@style/TextAppearance.EduReport.DrawerItem</item>
        <item name="subheaderTextAppearance">@style/TextAppearance.EduReport.DrawerHeader</item>
        <item name="itemShapeAppearance">@null</item>
        <item name="itemShapeFillColor">@color/transparent</item>
    </style>

    <style name="TextAppearance.EduReport.DrawerItem" parent="TextAppearance.Material3.LabelLarge">
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:textSize">14sp</item>
        <item name="android:textColor">?attr/colorOnSurface</item>
    </style>

    <style name="TextAppearance.EduReport.DrawerHeader" parent="TextAppearance.Material3.LabelMedium">
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:textSize">11sp</item>
        <item name="android:textColor">?attr/colorOnSurfaceVariant</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="DialogAnimationZoom">
        <item name="android:windowEnterAnimation">@anim/zoom_in</item>
        <item name="android:windowExitAnimation">@anim/zoom_out</item>
    </style>

    <style name="QrPreviewDialogTheme" parent="Theme.Material3.DayNight.Dialog">
        <item name="android:windowBackground">@android:color/transparent</item>
        <item name="android:windowFrame">@null</item>
        <item name="android:windowNoTitle">true</item>
        <item name="android:windowIsFloating">false</item>
        <item name="android:windowContentOverlay">@null</item>
        <item name="android:windowAnimationStyle">@style/DialogAnimationZoom</item>
        <item name="android:backgroundDimEnabled">true</item>
        <item name="android:backgroundDimAmount">0.85</item>
    </style>

    <style name="SingleSubjectMarksDialogTheme" parent="Theme.Material3.DayNight.Dialog">
        <item name="android:windowBackground">@android:color/transparent</item>
        <item name="android:windowFrame">@null</item>
        <item name="android:windowNoTitle">true</item>
        <item name="android:windowIsFloating">false</item>
        <item name="android:windowContentOverlay">@null</item>
        <item name="android:windowAnimationStyle">@style/DialogAnimationZoom</item>
        <item name="android:backgroundDimEnabled">true</item>
        <item name="android:backgroundDimAmount">0.60</item>
    </style>

    <style name="AttendanceEntryDialogTheme" parent="Theme.Material3.DayNight.Dialog">
        <item name="android:windowBackground">@android:color/transparent</item>
        <item name="android:windowFrame">@null</item>
        <item name="android:windowNoTitle">true</item>
        <item name="android:windowIsFloating">false</item>
        <item name="android:windowContentOverlay">@null</item>
        <item name="android:windowAnimationStyle">@style/DialogAnimationZoom</item>
        <item name="android:backgroundDimEnabled">true</item>
        <item name="android:backgroundDimAmount">0.60</item>
    </style>

    <!-- FAB Circle Shape -->
    <style name="ShapeAppearanceOverlay.App.FABCircle" parent="">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">50%</item>
    </style>
</resources>
