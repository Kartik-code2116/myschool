<?xml version="1.0" encoding="utf-8"?>
<paths>
    <external-files-path name="images"         path="images/"/>
    <external-files-path name="pdfs"           path="pdfs/"/>
    <external-files-path name="marksheets"     path="marksheets/"/>
    <!-- PdfGenerator saves to this directory — REQUIRED for FileProvider to open/share PDFs -->
    <external-files-path name="reports"        path="myschool_reports/"/>
    
    <!-- Required to open downloaded files from the public Downloads folder -->
    <external-public-path name="downloads"     path="Download/"/>
    <external-path name="external_downloads"   path="Download/"/>
    
    <!-- Required to share files from the internal cache directory (like excel_exports and backups) -->
    <cache-path name="internal_cache"          path="."/>
    
    <!-- Required to share files from the external cache directory -->
    <external-cache-path name="external_cache"  path="."/>
</paths>
