        android:name="com.example.myschool.ui.ReportPrintingFragment"
        android:label="Report Printing"/>

    <fragment
        android:id="@+id/nav_settings"
        android:name="com.example.myschool.ui.SettingsFragment"
        android:label="Settings"/>

</navigation>
