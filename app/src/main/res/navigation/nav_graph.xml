        android:name="com.example.myschool.ui.StudentListFragment"
        android:label="@string/menu_student_list"/>

    <fragment
        android:id="@+id/nav_reports"
        android:name="com.example.myschool.ui.ReportsFragment"
        android:label="@string/nav_reports"/>

    <fragment
        android:id="@+id/nav_profile"
        android:name="com.example.myschool.ui.ProfileFragment"
        android:label="@string/nav_profile"/>

    <fragment
        android:id="@+id/nav_formative"
        android:name="com.example.myschool.ui.PlaceholderFragment"
        android:label="@string/menu_formative_summative">
        <argument android:name="title" app:argType="string" android:defaultValue="Formative Summative"/>
    </fragment>

    <fragment
        android:id="@+id/nav_descriptive"
        android:name="com.example.myschool.ui.PlaceholderFragment"
        android:label="@string/menu_descriptive_entries">
        <argument android:name="title" app:argType="string" android:defaultValue="Descriptive Entries"/>
    </fragment>

    <fragment
        android:id="@+id/nav_attendance"
        android:name="com.example.myschool.ui.AttendanceFragment"
