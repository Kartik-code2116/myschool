<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    android:clipToPadding="false"
    android:overScrollMode="never"
    android:padding="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingBottom="24dp">

        <!-- 0. Subscription Status Card -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardSubscription"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="2dp"
            app:cardBackgroundColor="@color/surface">
            
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">
                
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Subscription Status"
                    android:textColor="@color/primary"
                    android:textSize="16sp"
                    android:fontFamily="sans-serif-medium"/>
                
                <TextView
                    android:id="@+id/tvSubscriptionStatus"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="Status: Loading..."
                    android:textColor="@color/on_surface"
                    android:textSize="14sp"
                    android:textStyle="bold"/>
                
                <TextView
                    android:id="@+id/tvSubscriptionExpiry"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="Valid till: N/A"
                    android:textColor="@color/on_surface_variant"
                    android:textSize="12sp"/>
                    
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnViewHistory"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:text="View History"
                    app:strokeColor="@color/primary"/>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- 1. App Theme Card -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardTheme"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="2dp"
            app:cardBackgroundColor="@color/surface">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/txt_app_theme"
                    android:textColor="@color/primary"
                    android:textSize="16sp"
                    android:fontFamily="sans-serif-medium"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:text="@string/txt_choose_how_myschool_appears_on"
                    android:textColor="@color/on_surface_variant"
                    android:textSize="12sp"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:orientation="horizontal">

                    <!-- System Default -->
                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/btnThemeSystem"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginEnd="6dp"
                        android:clickable="true"
                        android:focusable="true"
                        app:cardCornerRadius="12dp"
                        app:cardElevation="0dp"
                        app:strokeColor="@color/outline_variant"
                        app:strokeWidth="1dp">
                        <TextView
                            android:id="@+id/tvThemeSystem"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:gravity="center"
                            android:paddingVertical="12dp"
                            android:text="@string/txt_system"
                            android:textSize="13sp"
                            android:fontFamily="sans-serif-medium"/>
                    </com.google.android.material.card.MaterialCardView>

                    <!-- Light Mode -->
                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/btnThemeLight"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginEnd="6dp"
                        android:clickable="true"
                        android:focusable="true"
                        app:cardCornerRadius="12dp"
                        app:cardElevation="0dp"
                        app:strokeColor="@color/outline_variant"
                        app:strokeWidth="1dp">
                        <TextView
                            android:id="@+id/tvThemeLight"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:gravity="center"
                            android:paddingVertical="12dp"
                            android:text="@string/txt_light"
                            android:textSize="13sp"
                            android:fontFamily="sans-serif-medium"/>
                    </com.google.android.material.card.MaterialCardView>

                    <!-- Dark Mode -->
                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/btnThemeDark"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:clickable="true"
                        android:focusable="true"
                        app:cardCornerRadius="12dp"
                        app:cardElevation="0dp"
                        app:strokeColor="@color/outline_variant"
                        app:strokeWidth="1dp">
                        <TextView
                            android:id="@+id/tvThemeDark"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:gravity="center"
                            android:paddingVertical="12dp"
                            android:text="@string/txt_dark"
                            android:textSize="13sp"
                            android:fontFamily="sans-serif-medium"/>
                    </com.google.android.material.card.MaterialCardView>
                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- 2. App Language Card -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardLanguage"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="2dp"
            app:cardBackgroundColor="@color/surface">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/txt_app_language"
                    android:textColor="@color/primary"
                    android:textSize="16sp"
                    android:fontFamily="sans-serif-medium"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:text="@string/txt_choose_your_preferred_language"
                    android:textColor="@color/on_surface_variant"
                    android:textSize="12sp"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:orientation="horizontal">

                    <!-- English -->
                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/btnLangEn"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginEnd="8dp"
                        android:clickable="true"
                        android:focusable="true"
                        app:cardCornerRadius="12dp"
                        app:cardElevation="0dp"
                        app:strokeColor="@color/outline_variant"
                        app:strokeWidth="1dp">
                        <TextView
                            android:id="@+id/tvLangEn"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:gravity="center"
                            android:paddingVertical="12dp"
                            android:text="@string/txt_english"
                            android:textSize="14sp"
                            android:fontFamily="sans-serif-medium"/>
                    </com.google.android.material.card.MaterialCardView>

                    <!-- Marathi -->
                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/btnLangMr"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:clickable="true"
                        android:focusable="true"
                        app:cardCornerRadius="12dp"
                        app:cardElevation="0dp"
                        app:strokeColor="@color/outline_variant"
                        app:strokeWidth="1dp">
                        <TextView
                            android:id="@+id/tvLangMr"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:gravity="center"
                            android:paddingVertical="12dp"
                            android:text="@string/str_empty_14"
                            android:textSize="14sp"
                            android:fontFamily="sans-serif-medium"/>
                    </com.google.android.material.card.MaterialCardView>
                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- 3. Backup & Restore Card -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardBackup"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="2dp"
            app:cardBackgroundColor="@color/surface">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/txt_student_backup_amp_restore"
                    android:textColor="@color/primary"
                    android:textSize="16sp"
                    android:fontFamily="sans-serif-medium"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:text="@string/txt_export_class_students_data_or"
                    android:textColor="@color/on_surface_variant"
                    android:textSize="12sp"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:orientation="horizontal">

                    <!-- Export button -->
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnExportBackup"
                        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginEnd="8dp"
                        android:text="@string/txt_backup"
                        android:textSize="12sp"
                        app:strokeColor="@color/primary"
                        app:icon="@drawable/ic_copy"/>

                    <!-- Import button -->
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnImportBackup"
                        style="@style/Widget.MaterialComponents.Button"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/txt_restore"
                        android:textSize="12sp"
                        app:icon="@drawable/ic_add_box"/>
                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- 4. Cache Card -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardCache"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="2dp"
            app:cardBackgroundColor="@color/surface">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/txt_app_utilities_amp_cache"
                    android:textColor="@color/primary"
                    android:textSize="16sp"
                    android:fontFamily="sans-serif-medium"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:text="@string/txt_troubleshoot_or_reset_app_sett"
                    android:textColor="@color/on_surface_variant"
                    android:textSize="12sp"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:orientation="horizontal">

                    <!-- Reset active session -->
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnResetSession"
                        style="@style/Widget.MaterialComponents.Button.TextButton"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginEnd="8dp"
                        android:text="@string/txt_reset_session"
                        android:textColor="@color/accent_purple"
                        android:textSize="12sp"/>

                    <!-- Clear cache -->
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnClearCache"
                        style="@style/Widget.MaterialComponents.Button.TextButton"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/txt_clear_cache"
                        android:textColor="@color/accent_purple"
                        android:textSize="12sp"/>
                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>


        <!-- 5. AI Agent Card -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardAiAgent"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="2dp"
            app:cardBackgroundColor="@color/surface">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🤖 AI Agent Assistant"
                    android:textColor="@color/primary"
                    android:textSize="16sp"
                    android:fontFamily="sans-serif-medium"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:text="Show or hide the AI Assistant button in the bottom navigation bar."
                    android:textColor="@color/on_surface_variant"
                    android:textSize="12sp"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/tvAiAgentStatus"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="AI Assistant: ON"
                        android:textColor="@color/on_surface"
                        android:textSize="14sp"
                        android:fontFamily="sans-serif-medium"/>

                    <com.google.android.material.switchmaterial.SwitchMaterial
                        android:id="@+id/switchAiAgent"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:checked="true"
                        android:thumbTint="@color/primary"
                        android:trackTint="@color/primary_container"/>
                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- 6. App Info Card -->

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="16dp"
            app:cardElevation="2dp"
            app:cardBackgroundColor="@color/surface">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:orientation="vertical"
                android:padding="20dp">

                <ImageView
                    android:layout_width="56dp"
                    android:layout_height="56dp"
                    android:src="@drawable/ic_school"
                    app:tint="@color/primary"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="@string/txt_myschool_pro"
                    android:textColor="@color/on_surface"
                    android:textSize="18sp"
                    android:fontFamily="sans-serif-medium"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:text="@string/txt_smart_erp_for_school_results_a"
                    android:textColor="@color/on_surface_variant"
                    android:textSize="12sp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:text="@string/txt_version_1_0_0_build_2026_05"
                    android:textColor="@color/on_surface_variant"
                    android:textSize="11sp"
                    android:alpha="0.7"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:text="@string/txt_2026_advanced_agentic_coding_a"
                    android:textColor="@color/on_surface_variant"
                    android:textSize="10sp"
                    android:alpha="0.6"/>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>
    </LinearLayout>
</androidx.core.widget.NestedScrollView>
