<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/studentProfileRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    android:orientation="vertical"
    android:fitsSystemWindows="true">

    <!-- Premium Top App Bar (White background, dark accents) -->
    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="72dp"
        android:background="#FFFFFF"
        app:navigationIcon="@drawable/ic_chevron_left"
        app:navigationIconTint="#5A4FCF"
        app:title="@string/student_profile_title"
        app:titleTextColor="#2E2E2E"
        app:subtitleTextColor="#757575"
        app:titleCentered="false"
        app:elevation="2dp"/>

    <androidx.core.widget.NestedScrollView
        android:id="@+id/scrollStudentProfile"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:clipToPadding="false"
        android:fillViewport="true"
        android:overScrollMode="never"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="36dp">

            <!-- Profile Header Overlapping Block -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <!-- Header Background Banner with Photo Background -->
                <FrameLayout
                    android:id="@+id/layoutHeaderBanner"
                    android:layout_width="match_parent"
                    android:layout_height="190dp"
                    android:background="@drawable/bg_profile_header"
                    android:clipToOutline="true">

                    <!-- Background photo ImageView (student photo blurred/scaled) -->
                    <ImageView
                        android:id="@+id/ivHeaderBg"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:scaleType="centerCrop"
                        android:src="@drawable/bg_profile_header"
                        android:contentDescription="Profile background"/>

                    <!-- Semi-transparent dark overlay for text readability -->
                    <View
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="#55000000"/>

                    <!-- Content on top of the background -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:gravity="center_horizontal"
                        android:orientation="vertical"
                        android:paddingTop="20dp">

                        <TextView
                            android:id="@+id/tvStudentName"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/txt_student_name"
                            android:textColor="#FFFFFF"
                            android:textSize="24sp"
                            android:fontFamily="sans-serif-medium"
                            android:letterSpacing="0.02"
                            android:shadowColor="#88000000"
                            android:shadowDx="1"
                            android:shadowDy="1"
                            android:shadowRadius="3"/>

                        <!-- Standard & Division Subtitle line -->
                        <TextView
                            android:id="@+id/tvClassLine"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:textColor="#DDDDDD"
                            android:textSize="13sp"
                            android:fontFamily="sans-serif"
                            android:visibility="gone"/>

                        <!-- Pill-shaped Info Badges -->
                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="14dp"
                            android:gravity="center"
                            android:orientation="horizontal">

                            <!-- Registration Badge Pill -->
                            <LinearLayout
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:background="@drawable/bg_pill_info"
                                android:gravity="center"
                                android:paddingHorizontal="14dp"
                                android:paddingVertical="7dp">

                                <TextView
                                    android:id="@+id/tvTopRegNo"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="@string/txt_reg"
                                    android:textColor="#2E2E2E"
                                    android:textSize="13sp"
                                    android:fontFamily="sans-serif-medium"/>
                            </LinearLayout>

                            <!-- DOB Badge Pill -->
                            <LinearLayout
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="12dp"
                                android:background="@drawable/bg_pill_info"
                                android:gravity="center"
                                android:paddingHorizontal="14dp"
                                android:paddingVertical="7dp">

                                <TextView
                                    android:id="@+id/tvTopDob"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="—"
                                    android:textColor="#2E2E2E"
                                    android:textSize="13sp"
                                    android:fontFamily="sans-serif-medium"/>
                            </LinearLayout>
                        </LinearLayout>
                    </LinearLayout>
                </FrameLayout>

                <!-- Circular Avatar (Overlaps the bottom of the header section) -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardHeaderPhoto"
                    android:layout_width="96dp"
                    android:layout_height="96dp"
                    android:layout_below="@id/layoutHeaderBanner"
                    android:layout_centerHorizontal="true"
                    android:layout_marginTop="-48dp"
                    app:cardCornerRadius="48dp"
                    app:cardElevation="6dp"
                    app:strokeColor="#8BC34A"
                    app:strokeWidth="3.5dp"
                    app:cardBackgroundColor="#FFFFFF">

                    <ImageView
                        android:id="@+id/ivStudentPhoto"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:src="@drawable/ic_person"
                        android:contentDescription="Student Photo"/>
                </com.google.android.material.card.MaterialCardView>
            </RelativeLayout>

            <!-- Remaining Layout Content Wrapper -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingHorizontal="20dp"
                android:layout_marginTop="16dp">

                <!-- 1. Statistics Card (Roll 1, Roll 2, Gender, Cast with Green Values) -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardStats"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardCornerRadius="24dp"
                    app:cardElevation="2dp"
                    app:strokeWidth="0dp"
                    app:cardBackgroundColor="#FFFFFF">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:paddingVertical="18dp"
                        android:weightSum="4">

                        <!-- Column 1: Roll No 1 -->
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:gravity="center"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/txt_roll_no_1"
                                android:textColor="#757575"
                                android:textSize="11sp"
                                android:fontFamily="sans-serif-medium"/>

                            <TextView
                                android:id="@+id/tvTopRollNo"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="5dp"
                                android:text="—"
                                android:textColor="#8BC34A"
                                android:textSize="16sp"
                                android:fontFamily="sans-serif-bold"/>
                        </LinearLayout>

                        <View
                            android:layout_width="1dp"
                            android:layout_height="32dp"
                            android:layout_gravity="center_vertical"
                            android:background="@color/outline_variant"/>

                        <!-- Column 2: Roll No 2 -->
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:gravity="center"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/txt_roll_no_2"
                                android:textColor="#757575"
                                android:textSize="11sp"
                                android:fontFamily="sans-serif-medium"/>

                            <TextView
                                android:id="@+id/tvTopRollNo2"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="5dp"
                                android:text="—"
                                android:textColor="#8BC34A"
                                android:textSize="16sp"
                                android:fontFamily="sans-serif-bold"/>
                        </LinearLayout>

                        <View
                            android:layout_width="1dp"
                            android:layout_height="32dp"
                            android:layout_gravity="center_vertical"
                            android:background="@color/outline_variant"/>

                        <!-- Column 3: Gender -->
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:gravity="center"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/txt_gender"
                                android:textColor="#757575"
                                android:textSize="11sp"
                                android:fontFamily="sans-serif-medium"/>

                            <TextView
                                android:id="@+id/tvTopGender"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="5dp"
                                android:text="—"
                                android:textColor="#8BC34A"
                                android:textSize="16sp"
                                android:fontFamily="sans-serif-bold"/>
                        </LinearLayout>

                        <View
                            android:layout_width="1dp"
                            android:layout_height="32dp"
                            android:layout_gravity="center_vertical"
                            android:background="@color/outline_variant"/>

                        <!-- Column 4: Cast -->
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:gravity="center"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/txt_cast"
                                android:textColor="#757575"
                                android:textSize="11sp"
                                android:fontFamily="sans-serif-medium"/>

                            <TextView
                                android:id="@+id/tvTopCast"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="5dp"
                                android:text="—"
                                android:textColor="#8BC34A"
                                android:textSize="16sp"
                                android:fontFamily="sans-serif-bold"/>
                        </LinearLayout>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipMarksStatus"
                    style="@style/Widget.MaterialComponents.Chip.Action"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center_horizontal"
                    android:layout_marginTop="12dp"
                    android:layout_marginHorizontal="20dp"
                    android:clickable="false"
                    android:textSize="12sp"
                    android:fontFamily="sans-serif-medium"
                    android:visibility="gone"/>

                <!-- 3. Quick Section Navigation Chips Scroll Bar -->
                <HorizontalScrollView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:scrollbars="none"
                    android:overScrollMode="never">

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:paddingBottom="4dp">

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnNavBasic"
                            style="@style/Widget.MaterialComponents.Button.TextButton"
                            android:layout_width="wrap_content"
                            android:layout_height="38dp"
                            android:layout_marginEnd="8dp"
                            android:text="@string/txt_basic_info"
                            android:textSize="12sp"
                            android:insetTop="0dp"
                            android:insetBottom="0dp"
                            android:textColor="#8BC34A"
                            app:icon="@drawable/ic_person"
                            app:iconSize="14dp"
                            app:iconTint="#8BC34A"
                            app:backgroundTint="#F1F8E9"
                            app:cornerRadius="20dp"
                            android:fontFamily="sans-serif-medium"/>

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnNavFamily"
                            style="@style/Widget.MaterialComponents.Button.TextButton"
                            android:layout_width="wrap_content"
                            android:layout_height="38dp"
                            android:layout_marginEnd="8dp"
                            android:text="@string/txt_family_details"
                            android:textSize="12sp"
                            android:insetTop="0dp"
                            android:insetBottom="0dp"
                            android:textColor="#8BC34A"
                            app:icon="@drawable/ic_person"
                            app:iconSize="14dp"
                            app:iconTint="#8BC34A"
                            app:backgroundTint="#F1F8E9"
                            app:cornerRadius="20dp"
                            android:fontFamily="sans-serif-medium"/>

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnNavBank"
                            style="@style/Widget.MaterialComponents.Button.TextButton"
                            android:layout_width="wrap_content"
                            android:layout_height="38dp"
                            android:layout_marginEnd="8dp"
                            android:text="@string/txt_bank_details"
                            android:textSize="12sp"
                            android:insetTop="0dp"
                            android:insetBottom="0dp"
                            android:textColor="#8BC34A"
                            app:icon="@drawable/ic_id_card"
                            app:iconSize="14dp"
                            app:iconTint="#8BC34A"
                            app:backgroundTint="#F1F8E9"
                            app:cornerRadius="20dp"
                            android:fontFamily="sans-serif-medium"/>

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnNavAcademic"
                            style="@style/Widget.MaterialComponents.Button.TextButton"
                            android:layout_width="wrap_content"
                            android:layout_height="38dp"
                            android:text="@string/txt_academic_details"
                            android:textSize="12sp"
                            android:insetTop="0dp"
                            android:insetBottom="0dp"
                            android:textColor="#8BC34A"
                            app:icon="@drawable/ic_school"
                            app:iconSize="14dp"
                            app:iconTint="#8BC34A"
                            app:backgroundTint="#F1F8E9"
                            app:cornerRadius="20dp"
                            android:fontFamily="sans-serif-medium"/>
                    </LinearLayout>
                </HorizontalScrollView>

                <!-- 4. Basic Details Card -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardBasic"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    app:cardCornerRadius="24dp"
                    app:cardElevation="2dp"
                    app:strokeWidth="0dp"
                    app:cardBackgroundColor="#FFFFFF">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="20dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/section_basic_info"
                            android:textColor="#8BC34A"
                            android:textSize="15sp"
                            android:fontFamily="sans-serif-bold"/>

                        <LinearLayout
                            android:id="@+id/llBasicDetails"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="10dp"
                            android:orientation="vertical"/>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- 5. Family Details Card -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardFamily"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    app:cardCornerRadius="24dp"
                    app:cardElevation="2dp"
                    app:strokeWidth="0dp"
                    app:cardBackgroundColor="#FFFFFF">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="20dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/family_details"
                            android:textColor="#8BC34A"
                            android:textSize="15sp"
                            android:fontFamily="sans-serif-bold"/>

                        <LinearLayout
                            android:id="@+id/llFamilyDetails"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="10dp"
                            android:orientation="vertical"/>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- 6. Bank Details Card -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardBank"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    app:cardCornerRadius="24dp"
                    app:cardElevation="2dp"
                    app:strokeWidth="0dp"
                    app:cardBackgroundColor="#FFFFFF">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="20dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/bank_details"
                            android:textColor="#8BC34A"
                            android:textSize="15sp"
                            android:fontFamily="sans-serif-bold"/>

                        <LinearLayout
                            android:id="@+id/llBankDetails"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="10dp"
                            android:orientation="vertical"/>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- 7. Academic Details Card -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardAcademic"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    app:cardCornerRadius="24dp"
                    app:cardElevation="2dp"
                    app:strokeWidth="0dp"
                    app:cardBackgroundColor="#FFFFFF">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="20dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/section_academic_ids"
                            android:textColor="#8BC34A"
                            android:textSize="15sp"
                            android:fontFamily="sans-serif-bold"/>

                        <LinearLayout
                            android:id="@+id/llAcademicDetails"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="10dp"
                            android:orientation="vertical"/>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- CTA Action Buttons -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnEditStudent"
                    style="@style/Widget.EduReport.Button"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="24dp"
                    android:text="@string/edit_student"
                    android:textColor="#FFFFFF"
                    android:fontFamily="sans-serif-bold"
                    app:icon="@drawable/ic_edit_pencil"
                    app:iconGravity="textStart"
                    app:iconTint="#FFFFFF"
                    app:backgroundTint="#8BC34A"
                    android:elevation="2dp"/>


                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnSpecialCard"
                    style="@style/Widget.EduReport.Button"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:text="@string/view_special_card"
                    android:textColor="#FFFFFF"
                    android:fontFamily="sans-serif-bold"
                    app:icon="@drawable/ic_school"
                    app:iconGravity="textStart"
                    app:iconTint="#FFFFFF"
                    app:backgroundTint="#5A4FCF"
                    android:elevation="2dp"
                    android:minHeight="56dp"/>
            </LinearLayout>
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>
</LinearLayout>
