<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:layout_margin="6dp"
    app:cardCornerRadius="14dp"
    app:cardElevation="2dp"
    app:strokeWidth="0.8dp"
    app:strokeColor="#E0E0E0"
    app:cardBackgroundColor="@color/white">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="12dp">

        <!-- Subject Card Header -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp">

            <!-- Subject name and Grade Badge container -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_alignParentStart="true"
                android:layout_toStartOf="@+id/btnSubjectMore">

                <TextView
                    android:id="@+id/tvSubjectName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:ellipsize="end"
                    android:maxLines="1"
                    android:fontFamily="sans-serif-medium"
                    android:text="1. मराठी"
                    android:textColor="#37474F"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <!-- Grade Chip in Header -->
                <TextView
                    android:id="@+id/tvHeaderGrade"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:text="A-1"
                    android:textSize="10sp"
                    android:textStyle="bold"
                    android:paddingHorizontal="6dp"
                    android:paddingVertical="1.5dp"
                    android:textColor="#FFFFFF"
                    android:background="@drawable/bg_badge_pill" />
            </LinearLayout>

            <!-- Action: vertical 3-dot menu in top right -->
            <ImageView
                android:id="@+id/btnSubjectMore"
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:layout_alignParentEnd="true"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@drawable/ic_more_vert"
                app:tint="#6C4CCF"
                android:contentDescription="Subject Action" />
        </RelativeLayout>

        <!-- Formative Evaluation Label -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Formative Evaluation Weightage"
            android:textColor="#78909C"
            android:textSize="10sp"
            android:fontFamily="sans-serif-medium"
            android:layout_marginBottom="4dp" />

        <!-- Formative Table (8 columns) -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="12dp">

            <!-- FE1 -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="निरी."
                    android:gravity="center"
                    android:textColor="#78909C"
                    android:textSize="9sp"
                    android:padding="2dp"
                    android:background="@drawable/bg_table_cell" />
                <TextView
                    android:id="@+id/tvFE1"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="-"
                    android:gravity="center"
                    android:textColor="#37474F"
                    android:textSize="11sp"
                    android:padding="3dp"
                    android:background="@drawable/bg_table_cell" />
            </LinearLayout>

            <!-- FE2 -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="तोंडी."
                    android:gravity="center"
                    android:textColor="#78909C"
                    android:textSize="9sp"
                    android:padding="2dp"
                    android:background="@drawable/bg_table_cell" />
                <TextView
                    android:id="@+id/tvFE2"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="-"
                    android:gravity="center"
                    android:textColor="#37474F"
                    android:textSize="11sp"
                    android:padding="3dp"
                    android:background="@drawable/bg_table_cell" />
            </LinearLayout>

            <!-- FE3 -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="प्रात्य."
                    android:gravity="center"
                    android:textColor="#78909C"
                    android:textSize="9sp"
                    android:padding="2dp"
                    android:background="@drawable/bg_table_cell" />
                <TextView
                    android:id="@+id/tvFE3"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="-"
                    android:gravity="center"
                    android:textColor="#37474F"
                    android:textSize="11sp"
                    android:padding="3dp"
                    android:background="@drawable/bg_table_cell" />
            </LinearLayout>

            <!-- FE4 -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="उप."
                    android:gravity="center"
                    android:textColor="#78909C"
                    android:textSize="9sp"
                    android:padding="2dp"
                    android:background="@drawable/bg_table_cell" />
                <TextView
                    android:id="@+id/tvFE4"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="-"
                    android:gravity="center"
                    android:textColor="#37474F"
                    android:textSize="11sp"
                    android:padding="3dp"
                    android:background="@drawable/bg_table_cell" />
            </LinearLayout>

            <!-- FE5 -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="प्रक."
                    android:gravity="center"
                    android:textColor="#78909C"
                    android:textSize="9sp"
                    android:padding="2dp"
                    android:background="@drawable/bg_table_cell" />
                <TextView
                    android:id="@+id/tvFE5"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="-"
                    android:gravity="center"
                    android:textColor="#37474F"
                    android:textSize="11sp"
                    android:padding="3dp"
                    android:background="@drawable/bg_table_cell" />
            </LinearLayout>

            <!-- FE6 -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="चाच."
                    android:gravity="center"
                    android:textColor="#78909C"
                    android:textSize="9sp"
                    android:padding="2dp"
                    android:background="@drawable/bg_table_cell" />
                <TextView
                    android:id="@+id/tvFE6"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="-"
                    android:gravity="center"
                    android:textColor="#37474F"
                    android:textSize="11sp"
                    android:padding="3dp"
                    android:background="@drawable/bg_table_cell" />
            </LinearLayout>

            <!-- FE7 -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="स्वा."
                    android:gravity="center"
                    android:textColor="#78909C"
                    android:textSize="9sp"
                    android:padding="2dp"
                    android:background="@drawable/bg_table_cell" />
                <TextView
                    android:id="@+id/tvFE7"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="-"
                    android:gravity="center"
                    android:textColor="#37474F"
                    android:textSize="11sp"
                    android:padding="3dp"
                    android:background="@drawable/bg_table_cell" />
            </LinearLayout>

            <!-- FE8 -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="इतर"
                    android:gravity="center"
                    android:textColor="#78909C"
                    android:textSize="9sp"
                    android:padding="2dp"
                    android:background="@drawable/bg_table_cell" />
                <TextView
                    android:id="@+id/tvFE8"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="-"
                    android:gravity="center"
                    android:textColor="#37474F"
                    android:textSize="11sp"
                    android:padding="3dp"
                    android:background="@drawable/bg_table_cell" />
            </LinearLayout>
        </LinearLayout>

        <!-- Summative Evaluation Label -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Summative Evaluation Weightage"
            android:textColor="#78909C"
            android:textSize="10sp"
            android:fontFamily="sans-serif-medium"
            android:layout_marginBottom="4dp" />

        <!-- Summative Row (SE1-3 and FET/SET/TET) -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <!-- Left: SE1-3 -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="horizontal">

                <!-- SE1 -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="तोंडी."
                        android:gravity="center"
                        android:textColor="#78909C"
                        android:textSize="9sp"
                        android:padding="2dp"
                        android:background="@drawable/bg_table_cell" />
                    <TextView
                        android:id="@+id/tvSE1"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="-"
                        android:gravity="center"
                        android:textColor="#37474F"
                        android:textSize="11sp"
                        android:padding="3dp"
                        android:background="@drawable/bg_table_cell" />
                </LinearLayout>

                <!-- SE2 -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="प्रात्य."
                        android:gravity="center"
                        android:textColor="#78909C"
                        android:textSize="9sp"
                        android:padding="2dp"
                        android:background="@drawable/bg_table_cell" />
                    <TextView
                        android:id="@+id/tvSE2"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="-"
                        android:gravity="center"
                        android:textColor="#37474F"
                        android:textSize="11sp"
                        android:padding="3dp"
                        android:background="@drawable/bg_table_cell" />
                </LinearLayout>

                <!-- SE3 -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="लेखी"
                        android:gravity="center"
                        android:textColor="#78909C"
                        android:textSize="9sp"
                        android:padding="2dp"
                        android:background="@drawable/bg_table_cell" />
                    <TextView
                        android:id="@+id/tvSE3"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="-"
                        android:gravity="center"
                        android:textColor="#37474F"
                        android:textSize="11sp"
                        android:padding="3dp"
                        android:background="@drawable/bg_table_cell" />
                </LinearLayout>
            </LinearLayout>

            <!-- Spacing -->
            <View
                android:layout_width="12dp"
                android:layout_height="1dp" />

            <!-- Right: FET/SET/TET -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1.2"
                android:orientation="horizontal">

                <!-- FET -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="आका."
                        android:gravity="center"
                        android:textColor="#78909C"
                        android:textSize="9sp"
                        android:padding="2dp"
                        android:background="@drawable/bg_table_cell" />
                    <TextView
                        android:id="@+id/tvFET"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="-"
                        android:gravity="center"
                        android:textColor="#37474F"
                        android:textSize="11sp"
                        android:padding="3dp"
                        android:background="@drawable/bg_table_cell" />
                </LinearLayout>

                <!-- SET -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="संक."
                        android:gravity="center"
                        android:textColor="#78909C"
                        android:textSize="9sp"
                        android:padding="2dp"
                        android:background="@drawable/bg_table_cell" />
                    <TextView
                        android:id="@+id/tvSET"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="-"
                        android:gravity="center"
                        android:textColor="#37474F"
                        android:textSize="11sp"
                        android:padding="3dp"
                        android:background="@drawable/bg_table_cell" />
                </LinearLayout>

                <!-- TET -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="एकूण"
                        android:gravity="center"
                        android:textColor="#78909C"
                        android:textSize="9sp"
                        android:padding="2dp"
                        android:background="@drawable/bg_table_cell" />
                    <TextView
                        android:id="@+id/tvTET"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="-"
                        android:gravity="center"
                        android:textColor="#6C4CCF"
                        android:textStyle="bold"
                        android:textSize="11sp"
                        android:padding="3dp"
                        android:background="@drawable/bg_table_cell" />
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>

    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
