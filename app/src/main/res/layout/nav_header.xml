<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_drawer_header"
    android:orientation="vertical"
    android:padding="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <ImageView
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="@drawable/bg_circle_primary"
            android:padding="10dp"
            android:src="@drawable/ic_school"
            app:tint="@color/white"/>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvDrawerAppName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="sans-serif-medium"
                android:text="@string/drawer_app_name"
                android:textColor="@color/drawer_header_dark"
                android:textSize="20sp"/>

            <TextView
                android:id="@+id/tvDrawerTeacherId"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/on_surface_variant"
                android:textSize="12sp"/>
        </LinearLayout>
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="14dp"
        android:orientation="horizontal">

        <ImageButton
            android:id="@+id/btnDrawerStats"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_marginEnd="6dp"
            android:layout_weight="1"
            android:background="@drawable/bg_surface_rounded"
            android:contentDescription="@string/drawer_stats"
            android:padding="10dp"
            android:src="@drawable/ic_chart"
            app:tint="@color/drawer_header_dark"/>

        <ImageButton
            android:id="@+id/btnDrawerSettings"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_marginEnd="6dp"
            android:layout_weight="1"
            android:background="@drawable/bg_surface_rounded"
            android:contentDescription="@string/drawer_settings"
            android:padding="10dp"
            android:src="@drawable/ic_settings"
            app:tint="@color/drawer_header_dark"/>

        <ImageButton
            android:id="@+id/btnDrawerPrint"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_marginEnd="6dp"
            android:layout_weight="1"
            android:background="@drawable/bg_surface_rounded"
            android:contentDescription="@string/drawer_print"
            android:padding="10dp"
            android:src="@drawable/ic_print"
            app:tint="@color/drawer_header_dark"/>

        <ImageButton
            android:id="@+id/btnDrawerProfile"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_weight="1"
            android:background="@drawable/bg_surface_rounded"
            android:contentDescription="@string/profile_title"
            android:padding="10dp"
            android:src="@drawable/ic_person"
            app:tint="@color/drawer_header_dark"/>
    </LinearLayout>
</LinearLayout>
