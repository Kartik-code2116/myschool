<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/background">

    <!-- Simple Custom AppBar -->
    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="?attr/colorSurface"
        app:elevation="2dp">
        <androidx.appcompat.widget.Toolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            app:navigationIcon="@drawable/ic_chevron_left"
            app:title="@string/msg_attendance_analytics"
            app:titleTextColor="?attr/colorOnSurface"/>
    </com.google.android.material.appbar.AppBarLayout>

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <androidx.core.widget.NestedScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:clipToPadding="false"
            android:paddingBottom="24dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <!-- Header Strip Info -->
                <TextView
                    android:id="@+id/tvReportContext"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_gradient_primary"
                    android:fontFamily="sans-serif-medium"
                    android:padding="10dp"
                    android:text="Year: 2025-26 | Cls: 5-1"
                    android:textColor="#FFFFFF"
                    android:textSize="13sp"
                    android:layout_marginBottom="16dp"
                    app:drawableStartCompat="@drawable/ic_info"
                    app:drawableTint="#FFFFFF"
                    android:drawablePadding="8dp" />

                <!-- Summary Card -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="24dp"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="2dp"
                    app:strokeWidth="1dp"
                    app:strokeColor="?attr/colorOutlineVariant"
                    app:cardBackgroundColor="?attr/colorSurface">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical">
                            <ImageView
                                android:layout_width="32dp"
                                android:layout_height="32dp"
                                android:src="@drawable/ic_reports"
                                app:tint="?attr/colorPrimary"
                                android:layout_marginEnd="12dp"
                                android:background="@drawable/bg_circle"
                                android:backgroundTint="#1A6C4CCF"
                                android:padding="6dp"/>
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Class Summary"
                                android:textSize="18sp"
                                android:textStyle="bold"
                                android:textColor="?attr/colorOnSurface"/>
                        </LinearLayout>

                        <View
                            android:layout_width="match_parent"
                            android:layout_height="1dp"
                            android:layout_marginTop="12dp"
                            android:layout_marginBottom="12dp"
                            android:background="?attr/colorOutlineVariant" />

                        <GridLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:columnCount="2"
                            android:rowCount="3"
                            android:alignmentMode="alignMargins">

                            <!-- Total Students -->
                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_columnWeight="1"
                                android:orientation="vertical"
                                android:layout_marginBottom="16dp">
                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Total Students"
                                    android:textSize="12sp"
                                    android:textColor="?attr/colorOnSurfaceVariant"/>
                                <TextView
                                    android:id="@+id/tvTotalStudents"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    tools:text="45"
                                    android:textSize="18sp"
                                    android:textStyle="bold"
                                    android:textColor="?attr/colorPrimary"/>
                            </LinearLayout>

                            <!-- Average Attendance -->
                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_columnWeight="1"
                                android:orientation="vertical"
                                android:layout_marginBottom="16dp">
                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Avg Attendance"
                                    android:textSize="12sp"
                                    android:textColor="?attr/colorOnSurfaceVariant"/>
                                <TextView
                                    android:id="@+id/tvAvgAttendance"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    tools:text="85.4%"
                                    android:textSize="18sp"
                                    android:textStyle="bold"
                                    android:textColor="#00A5CF"/>
                            </LinearLayout>

                            <!-- Total Present -->
                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_columnWeight="1"
                                android:orientation="vertical"
                                android:layout_marginBottom="16dp">
                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Total Present Days"
                                    android:textSize="12sp"
                                    android:textColor="?attr/colorOnSurfaceVariant"/>
                                <TextView
                                    android:id="@+id/tvTotalPresent"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    tools:text="1450"
                                    android:textSize="18sp"
                                    android:textStyle="bold"
                                    android:textColor="#4CAF50"/>
                            </LinearLayout>

                            <!-- Total Working -->
                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_columnWeight="1"
                                android:orientation="vertical"
                                android:layout_marginBottom="16dp">
                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Total Working Days"
                                    android:textSize="12sp"
                                    android:textColor="?attr/colorOnSurfaceVariant"/>
                                <TextView
                                    android:id="@+id/tvTotalWorking"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    tools:text="1720"
                                    android:textSize="18sp"
                                    android:textStyle="bold"
                                    android:textColor="#E65100"/>
                            </LinearLayout>

                            <!-- Best Attender -->
                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_columnWeight="2"
                                android:layout_columnSpan="2"
                                android:orientation="vertical"
                                android:background="@drawable/bg_surface_rounded"
                                android:backgroundTint="#1A9C27B0"
                                android:padding="12dp">
                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Best Attending Student"
                                    android:textSize="12sp"
                                    android:textColor="?attr/colorOnSurfaceVariant"/>
                                <TextView
                                    android:id="@+id/tvBestAttender"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    tools:text="Rahul Sharma (99%)"
                                    android:textSize="16sp"
                                    android:textStyle="bold"
                                    android:textColor="#9C27B0"/>
                            </LinearLayout>

                        </GridLayout>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Student Wise Details"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="?attr/colorOnSurface"
                    android:layout_marginBottom="12dp"
                    android:layout_marginStart="4dp"/>

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rvReportStudents"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:nestedScrollingEnabled="false"
                    tools:listitem="@layout/item_attendance_report_student"/>

            </LinearLayout>
        </androidx.core.widget.NestedScrollView>

        <!-- Loading View -->
        <ProgressBar
            android:id="@+id/progressBar"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:visibility="gone"/>

        <!-- Empty State -->
        <TextView
            android:id="@+id/tvEmptyState"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:text="@string/msg_empty_1"
            android:textColor="?attr/colorOnSurfaceVariant"
            android:visibility="gone"
            android:drawableTop="@drawable/ic_search"
            android:drawablePadding="8dp"
            android:drawableTint="?attr/colorOnSurfaceVariant"/>

    </FrameLayout>
</LinearLayout>
