<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F2F2F2"
    android:orientation="vertical"
    android:fitsSystemWindows="true">

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="72dp"
        android:background="#FFFFFF"
        app:navigationIcon="@drawable/ic_close"
        app:navigationIconTint="#5A4FCF"
        app:title="@string/edit_student"
        app:titleTextColor="#2E2E2E"
        app:titleCentered="false"
        app:elevation="2dp"/>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true"
        android:clipToPadding="false"
        android:paddingBottom="24dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- BASIC INFORMATION CARD -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="16dp"
                app:cardElevation="2dp"
                app:strokeWidth="0dp"
                app:cardBackgroundColor="@color/white"
                android:layout_marginBottom="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Basic Information"
                        android:textColor="#5A4FCF"
                        android:textSize="16sp"
                        android:layout_marginBottom="16dp"
                        android:fontFamily="sans-serif-black"/>

                    <com.google.android.material.textfield.TextInputLayout style="@style/Widget.EduReport.TextInputLayout"
                        android:layout_width="match_parent" android:layout_height="wrap_content" android:hint="@string/label_student_name">
                        <com.google.android.material.textfield.TextInputEditText android:id="@+id/etName" android:layout_width="match_parent" android:layout_height="wrap_content" android:singleLine="true"/>
                    </com.google.android.material.textfield.TextInputLayout>
                    <com.google.android.material.textfield.TextInputLayout style="@style/Widget.EduReport.TextInputLayout"
                        android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="12dp" android:hint="@string/label_roll_no">
                        <com.google.android.material.textfield.TextInputEditText android:id="@+id/etRoll1" android:layout_width="match_parent" android:layout_height="wrap_content" android:inputType="number" android:singleLine="true"/>
                    </com.google.android.material.textfield.TextInputLayout>
                    <com.google.android.material.textfield.TextInputLayout style="@style/Widget.EduReport.TextInputLayout"
                        android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="12dp" android:hint="@string/label_roll_no_2">
                        <com.google.android.material.textfield.TextInputEditText android:id="@+id/etRoll2" android:layout_width="match_parent" android:layout_height="wrap_content" android:inputType="number" android:singleLine="true"/>
                    </com.google.android.material.textfield.TextInputLayout>
                    <com.google.android.material.textfield.TextInputLayout style="@style/Widget.EduReport.TextInputLayout"
                        android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="12dp" android:hint="@string/label_reg_no">
                        <com.google.android.material.textfield.TextInputEditText android:id="@+id/etRegNo" android:layout_width="match_parent" android:layout_height="wrap_content" android:inputType="number" android:singleLine="true"/>
                    </com.google.android.material.textfield.TextInputLayout>
                    <com.google.android.material.textfield.TextInputLayout android:id="@+id/tilDob"
                        style="@style/Widget.EduReport.TextInputLayout"
                        android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:layout_marginTop="12dp" android:hint="@string/label_dob"
                        app:endIconDrawable="@drawable/ic_calendar" app:endIconMode="custom">
                        <com.google.android.material.textfield.TextInputEditText android:id="@+id/etDob" android:layout_width="match_parent" android:layout_height="wrap_content" android:singleLine="true"/>
                    </com.google.android.material.textfield.TextInputLayout>
                    <com.google.android.material.textfield.TextInputLayout style="@style/Widget.Material3.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
                        android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="12dp" android:hint="@string/label_gender">
                        <AutoCompleteTextView android:id="@+id/etGender" android:layout_width="match_parent" android:layout_height="wrap_content" android:inputType="none" android:singleLine="true"/>
                    </com.google.android.material.textfield.TextInputLayout>
                    <com.google.android.material.textfield.TextInputLayout style="@style/Widget.Material3.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
                        android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="12dp" android:hint="@string/label_cast">
                        <AutoCompleteTextView android:id="@+id/etCast" android:layout_width="match_parent" android:layout_height="wrap_content" android:inputType="none" android:singleLine="true"/>
                    </com.google.android.material.textfield.TextInputLayout>
                    <com.google.android.material.textfield.TextInputLayout style="@style/Widget.EduReport.TextInputLayout"
                        android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="12dp" android:hint="@string/label_birthplace">
                        <com.google.android.material.textfield.TextInputEditText android:id="@+id/etBirthPlace" android:layout_width="match_parent" android:layout_height="wrap_content" android:singleLine="true"/>
                    </com.google.android.material.textfield.TextInputLayout>
                    <com.google.android.material.textfield.TextInputLayout style="@style/Widget.EduReport.TextInputLayout"
                        android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="12dp" android:hint="@string/label_religion">
                        <com.google.android.material.textfield.TextInputEditText android:id="@+id/etReligion" android:layout_width="match_parent" android:layout_height="wrap_content" android:singleLine="true"/>
                    </com.google.android.material.textfield.TextInputLayout>
                    <com.google.android.material.textfield.TextInputLayout style="@style/Widget.EduReport.TextInputLayout"
                        android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="12dp" android:hint="@string/label_blood_group">
                        <com.google.android.material.textfield.TextInputEditText android:id="@+id/etBloodGroup" android:layout_width="match_parent" android:layout_height="wrap_content" android:singleLine="true"/>
                    </com.google.android.material.textfield.TextInputLayout>
                    
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:orientation="horizontal">
                        <com.google.android.material.textfield.TextInputLayout style="@style/Widget.EduReport.TextInputLayout"
                            android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content" android:layout_marginEnd="6dp" android:hint="@string/label_standard">
                            <com.google.android.material.textfield.TextInputEditText android:id="@+id/etStandard" android:layout_width="match_parent" android:layout_height="wrap_content" android:singleLine="true"/>
                        </com.google.android.material.textfield.TextInputLayout>
                        <com.google.android.material.textfield.TextInputLayout style="@style/Widget.EduReport.TextInputLayout"
                            android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content" android:layout_marginStart="6dp" android:hint="@string/label_division">
                            <com.google.android.material.textfield.TextInputEditText android:id="@+id/etDivision" android:layout_width="match_parent" android:layout_height="wrap_content" android:singleLine="true"/>
                        </com.google.android.material.textfield.TextInputLayout>
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:orientation="horizontal">
                        <com.google.android.material.textfield.TextInputLayout style="@style/Widget.EduReport.TextInputLayout"
                            android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content" android:layout_marginEnd="6dp" android:hint="@string/label_height_sem1">
                            <com.google.android.material.textfield.TextInputEditText android:id="@+id/etHeightSem1" android:layout_width="match_parent" android:layout_height="wrap_content" android:singleLine="true"/>
                        </com.google.android.material.textfield.TextInputLayout>
                        <com.google.android.material.textfield.TextInputLayout style="@style/Widget.EduReport.TextInputLayout"
                            android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content" android:layout_marginStart="6dp" android:hint="@string/label_weight_sem1">
                            <com.google.android.material.textfield.TextInputEditText android:id="@+id/etWeightSem1" android:layout_width="match_parent" android:layout_height="wrap_content" android:singleLine="true"/>
                        </com.google.android.material.textfield.TextInputLayout>
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:orientation="horizontal">
                        <com.google.android.material.textfield.TextInputLayout style="@style/Widget.EduReport.TextInputLayout"
                            android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content" android:layout_marginEnd="6dp" android:hint="@string/label_height_sem2">
                            <com.google.android.material.textfield.TextInputEditText android:id="@+id/etHeightSem2" android:layout_width="match_parent" android:layout_height="wrap_content" android:singleLine="true"/>
                        </com.google.android.material.textfield.TextInputLayout>
                        <com.google.android.material.textfield.TextInputLayout style="@style/Widget.EduReport.TextInputLayout"
                            android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content" android:layout_marginStart="6dp" android:hint="@string/label_weight_sem2">
                            <com.google.android.material.textfield.TextInputEditText android:id="@+id/etWeightSem2" android:layout_width="match_parent" android:layout_height="wrap_content" android:singleLine="true"/>
                        </com.google.android.material.textfield.TextInputLayout>
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- FAMILY DETAILS CARD -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="16dp"
                app:cardElevation="2dp"
                app:strokeWidth="0dp"
                app:cardBackgroundColor="@color/white"
                android:layout_marginBottom="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/family_details"
                        android:textColor="#5A4FCF"
                        android:textSize="16sp"
                        android:layout_marginBottom="16dp"
                        android:fontFamily="sans-serif-black"/>

                    <com.google.android.material.textfield.TextInputLayout style="@style/Widget.EduReport.TextInputLayout"
                        android:layout_width="match_parent" android:layout_height="wrap_content" android:hint="@string/label_mother_name">
                        <com.google.android.material.textfield.TextInputEditText android:id="@+id/etMotherName" android:layout_width="match_parent" android:layout_height="wrap_content" android:singleLine="true"/>
                    </com.google.android.material.textfield.TextInputLayout>
                    <com.google.android.material.textfield.TextInputLayout style="@style/Widget.EduReport.TextInputLayout"
                        android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="12dp" android:hint="@string/label_mother_occupation">
                        <com.google.android.material.textfield.TextInputEditText android:id="@+id/etMotherOccupation" android:layout_width="match_parent" android:layout_height="wrap_content" android:singleLine="true"/>
                    </com.google.android.material.textfield.TextInputLayout>
                    <com.google.android.material.textfield.TextInputLayout style="@style/Widget.EduReport.TextInputLayout"
                        android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="12dp" android:hint="@string/label_mother_phone">
                        <com.google.android.material.textfield.TextInputEditText android:id="@+id/etMotherPhone" android:layout_width="match_parent" android:layout_height="wrap_content" android:inputType="phone" android:maxLength="10" android:singleLine="true"/>
                    </com.google.android.material.textfield.TextInputLayout>
                    <com.google.android.material.textfield.TextInputLayout style="@style/Widget.EduReport.TextInputLayout"
                        android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="12dp" android:hint="@string/label_father_name">
                        <com.google.android.material.textfield.TextInputEditText android:id="@+id/etFatherName" android:layout_width="match_parent" android:layout_height="wrap_content" android:singleLine="true"/>
                    </com.google.android.material.textfield.TextInputLayout>
                    <com.google.android.material.textfield.TextInputLayout style="@style/Widget.EduReport.TextInputLayout"
                        android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="12dp" android:hint="@string/label_father_occupation">
                        <com.google.android.material.textfield.TextInputEditText android:id="@+id/etFatherOccupation" android:layout_width="match_parent" android:layout_height="wrap_content" android:singleLine="true"/>
                    </com.google.android.material.textfield.TextInputLayout>
                    <com.google.android.material.textfield.TextInputLayout style="@style/Widget.EduReport.TextInputLayout"
                        android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="12dp" android:hint="@string/label_father_phone">
                        <com.google.android.material.textfield.TextInputEditText android:id="@+id/etFatherPhone" android:layout_width="match_parent" android:layout_height="wrap_content" android:inputType="phone" android:maxLength="10" android:singleLine="true"/>
                    </com.google.android.material.textfield.TextInputLayout>
                    <com.google.android.material.textfield.TextInputLayout style="@style/Widget.EduReport.TextInputLayout"
                        android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="12dp" android:hint="@string/label_home_address">
                        <com.google.android.material.textfield.TextInputEditText android:id="@+id/etAddress" android:layout_width="match_parent" android:layout_height="wrap_content" android:minLines="2"/>
                    </com.google.android.material.textfield.TextInputLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- BANK DETAILS CARD -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="16dp"
                app:cardElevation="2dp"
                app:strokeWidth="0dp"
                app:cardBackgroundColor="@color/white"
                android:layout_marginBottom="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/bank_details"
                        android:textColor="#5A4FCF"
                        android:textSize="16sp"
                        android:layout_marginBottom="16dp"
                        android:fontFamily="sans-serif-black"/>

                    <com.google.android.material.textfield.TextInputLayout style="@style/Widget.EduReport.TextInputLayout"
                        android:layout_width="match_parent" android:layout_height="wrap_content" android:hint="@string/label_bank_name">
                        <com.google.android.material.textfield.TextInputEditText android:id="@+id/etBankName" android:layout_width="match_parent" android:layout_height="wrap_content" android:inputType="textCapWords" android:singleLine="true"/>
                    </com.google.android.material.textfield.TextInputLayout>
                    <com.google.android.material.textfield.TextInputLayout style="@style/Widget.EduReport.TextInputLayout"
                        android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="12dp" android:hint="@string/label_account_no">
                        <com.google.android.material.textfield.TextInputEditText android:id="@+id/etBankAccount" android:layout_width="match_parent" android:layout_height="wrap_content" android:inputType="number" android:maxLength="20" android:singleLine="true"/>
                    </com.google.android.material.textfield.TextInputLayout>
                    <com.google.android.material.textfield.TextInputLayout style="@style/Widget.EduReport.TextInputLayout"
                        android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="12dp" android:hint="@string/label_branch">
                        <com.google.android.material.textfield.TextInputEditText android:id="@+id/etBankBranch" android:layout_width="match_parent" android:layout_height="wrap_content" android:inputType="textCapWords" android:singleLine="true"/>
                    </com.google.android.material.textfield.TextInputLayout>
                    <com.google.android.material.textfield.TextInputLayout style="@style/Widget.EduReport.TextInputLayout"
                        android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="12dp" android:hint="@string/label_ifsc">
                        <com.google.android.material.textfield.TextInputEditText android:id="@+id/etBankIfsc" android:layout_width="match_parent" android:layout_height="wrap_content" android:inputType="textCapCharacters" android:maxLength="11" android:singleLine="true"/>
                    </com.google.android.material.textfield.TextInputLayout>
                    <com.google.android.material.textfield.TextInputLayout style="@style/Widget.EduReport.TextInputLayout"
                        android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="12dp" android:hint="@string/label_uid">
                        <com.google.android.material.textfield.TextInputEditText android:id="@+id/etBankUid" android:layout_width="match_parent" android:layout_height="wrap_content" android:inputType="number" android:maxLength="12" android:singleLine="true"/>
                    </com.google.android.material.textfield.TextInputLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- ACADEMIC RECORDS CARD -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="16dp"
                app:cardElevation="2dp"
                app:strokeWidth="0dp"
                app:cardBackgroundColor="@color/white"
                android:layout_marginBottom="24dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Academic Records"
                        android:textColor="#5A4FCF"
                        android:textSize="16sp"
                        android:layout_marginBottom="16dp"
                        android:fontFamily="sans-serif-black"/>

                    <com.google.android.material.textfield.TextInputLayout style="@style/Widget.Material3.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
                        android:layout_width="match_parent" android:layout_height="wrap_content" android:hint="@string/label_medium">
                        <AutoCompleteTextView android:id="@+id/etMedium" android:layout_width="match_parent" android:layout_height="wrap_content" android:inputType="none" android:singleLine="true"/>
                    </com.google.android.material.textfield.TextInputLayout>
                    <com.google.android.material.textfield.TextInputLayout style="@style/Widget.Material3.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
                        android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="12dp" android:hint="@string/label_mother_tongue">
                        <AutoCompleteTextView android:id="@+id/etMotherTongue" android:layout_width="match_parent" android:layout_height="wrap_content" android:inputType="none" android:singleLine="true"/>
                    </com.google.android.material.textfield.TextInputLayout>
                    <com.google.android.material.textfield.TextInputLayout android:id="@+id/tilDateAdmission"
                        style="@style/Widget.EduReport.TextInputLayout"
                        android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:layout_marginTop="12dp" android:hint="@string/label_date_admission"
                        app:endIconDrawable="@drawable/ic_calendar" app:endIconMode="custom">
                        <com.google.android.material.textfield.TextInputEditText android:id="@+id/etDateAdmission" android:layout_width="match_parent" android:layout_height="wrap_content" android:singleLine="true"/>
                    </com.google.android.material.textfield.TextInputLayout>
                    <com.google.android.material.textfield.TextInputLayout style="@style/Widget.EduReport.TextInputLayout"
                        android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="12dp" android:hint="@string/label_student_id">
                        <com.google.android.material.textfield.TextInputEditText android:id="@+id/etStudentId" android:layout_width="match_parent" android:layout_height="wrap_content" android:inputType="number" android:maxLength="19" android:singleLine="true"/>
                    </com.google.android.material.textfield.TextInputLayout>
                    <com.google.android.material.textfield.TextInputLayout style="@style/Widget.EduReport.TextInputLayout"
                        android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="12dp" android:hint="@string/label_uid">
                        <com.google.android.material.textfield.TextInputEditText android:id="@+id/etUid" android:layout_width="match_parent" android:layout_height="wrap_content" android:inputType="number" android:maxLength="12" android:singleLine="true"/>
                    </com.google.android.material.textfield.TextInputLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnSaveStudent"
                style="@style/Widget.EduReport.Button"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:textSize="16sp"
                app:cornerRadius="30dp"
                android:text="@string/btn_save_student"/>

            <com.google.android.material.progressindicator.LinearProgressIndicator
                android:id="@+id/progress"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:indeterminate="true"
                android:visibility="gone"/>
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>
</LinearLayout>
