<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent" android:layout_height="wrap_content"
    android:layout_marginStart="4dp" android:layout_marginEnd="4dp" android:layout_marginBottom="10dp"
    app:cardCornerRadius="16dp" app:cardElevation="2dp" app:cardBackgroundColor="@color/surface"
    android:clickable="true" android:focusable="true">
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="horizontal" android:padding="14dp" android:gravity="center_vertical">
        <com.google.android.material.card.MaterialCardView android:layout_width="52dp" android:layout_height="52dp"
            app:cardCornerRadius="26dp" app:cardElevation="0dp" app:cardBackgroundColor="@color/secondary_container">
            <ImageView android:id="@+id/ivSchoolLogo"
                android:layout_width="match_parent" android:layout_height="match_parent"
                android:src="@drawable/ic_school" android:padding="12dp" app:tint="@color/secondary"/>
        </com.google.android.material.card.MaterialCardView>
        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:orientation="vertical" android:layout_marginStart="14dp">
            <TextView android:id="@+id/tvSchoolCardName"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="@string/txt_school_name" android:textSize="15sp"
                android:fontFamily="sans-serif-medium" android:textColor="@color/on_surface"/>
            <TextView android:id="@+id/tvSchoolCardBoard"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:layout_marginTop="2dp" android:text="@string/txt_cbse"
                android:textSize="12sp" android:textColor="@color/on_surface_variant"/>
            <TextView android:id="@+id/tvSchoolCardStudentCount"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:layout_marginTop="2dp" android:text="@string/txt_0_students_1"
                android:textSize="11sp" android:textColor="@color/on_surface_variant"/>
        </LinearLayout>
        <ImageView android:layout_width="20dp" android:layout_height="20dp"
            android:src="@drawable/ic_reports" app:tint="@color/on_surface_variant" android:alpha="0.5"/>
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
