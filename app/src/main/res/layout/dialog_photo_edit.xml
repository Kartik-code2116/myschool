<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="24dp"
    app:cardCornerRadius="24dp"
    app:cardElevation="8dp"
    app:strokeWidth="0dp"
    app:cardBackgroundColor="?attr/colorSurface">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- Header -->
        <TextView
            android:id="@+id/tvDialogTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Edu Report"
            android:textColor="#2E2E2E"
            android:textSize="20sp"
            android:fontFamily="sans-serif-medium"
            android:layout_marginBottom="16dp"/>

        <!-- Center Image Frame -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="300dp"
            android:background="?attr/colorSurfaceVariant"
            android:layout_marginBottom="20dp">

            <ImageView
                android:id="@+id/ivPhotoPreview"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerInside"
                android:contentDescription="Student Photo"/>
        </FrameLayout>

        <!-- Bottom Action Buttons Row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:weightSum="5">

            <!-- Camera button -->
            <ImageButton
                android:id="@+id/btnCamera"
                android:layout_width="0dp"
                android:layout_height="56dp"
                android:layout_weight="1"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@android:drawable/ic_menu_camera"
                app:tint="?attr/colorPrimary"
                android:contentDescription="Take Photo"/>

            <!-- Crop button -->
            <ImageButton
                android:id="@+id/btnCrop"
                android:layout_width="0dp"
                android:layout_height="56dp"
                android:layout_weight="1"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@drawable/ic_crop"
                app:tint="?attr/colorPrimary"
                android:contentDescription="Crop Photo"/>

            <!-- Delete button -->
            <ImageButton
                android:id="@+id/btnDelete"
                android:layout_width="0dp"
                android:layout_height="56dp"
                android:layout_weight="1"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@drawable/ic_delete"
                app:tint="#E53935"
                android:contentDescription="Delete Photo"/>

            <!-- Rotate button -->
            <ImageButton
                android:id="@+id/btnRotate"
                android:layout_width="0dp"
                android:layout_height="56dp"
                android:layout_weight="1"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@drawable/ic_rotate_right"
                app:tint="?attr/colorPrimary"
                android:contentDescription="Rotate Photo"/>

            <!-- Save button -->
            <ImageButton
                android:id="@+id/btnSave"
                android:layout_width="0dp"
                android:layout_height="56dp"
                android:layout_weight="1"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@drawable/ic_save"
                app:tint="#8BC34A"
                android:contentDescription="Save Photo"/>

        </LinearLayout>
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
