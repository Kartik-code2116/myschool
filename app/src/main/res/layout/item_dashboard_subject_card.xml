<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginStart="14dp"
    android:layout_marginEnd="14dp"
    android:layout_marginBottom="16dp"
    app:cardCornerRadius="14dp"
    app:cardElevation="3dp"
    app:strokeWidth="1dp"
    app:strokeColor="#E0E0E0"
    app:cardBackgroundColor="@color/white">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Subject Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="16dp">

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_menu_book"
                app:tint="#455A64"
                android:layout_marginEnd="8dp"/>

            <TextView
                android:id="@+id/tvSubjectName"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:fontFamily="sans-serif-bold"
                android:textColor="#263238"
                android:textSize="16sp"
                android:text="@string/txt_1_marathi" />
                
            <com.google.android.material.chip.Chip
                android:id="@+id/chipCompletionStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="100%"
                app:chipMinHeight="24dp"
                android:textSize="11sp"
                android:textColor="#FFFFFF"
                app:chipBackgroundColor="#4CAF50"
                app:ensureMinTouchTargetSize="false"
                android:clickable="false"/>
        </LinearLayout>

        <!-- Formative Progress -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginBottom="12dp">
            
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="4dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/txt_formative_progress"
                    android:textSize="12sp"
                    android:textColor="#1976D2"
                    android:fontFamily="sans-serif-medium"/>
                <TextView
                    android:id="@+id/tvFormativeCount"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentEnd="true"
                    android:text="0 / 40"
                    android:textSize="12sp"
                    android:textColor="#546E7A"
                    android:fontFamily="sans-serif-bold"/>
            </RelativeLayout>
            
            <ProgressBar
                android:id="@+id/pbFormative"
                style="?android:attr/progressBarStyleHorizontal"
                android:layout_width="match_parent"
                android:layout_height="8dp"
                android:progressDrawable="@drawable/custom_progress_blue"
                android:max="100"
                android:progress="0"/>
        </LinearLayout>

        <!-- Summative Progress -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginBottom="12dp">
            
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="4dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/txt_summative_progress"
                    android:textSize="12sp"
                    android:textColor="#388E3C"
                    android:fontFamily="sans-serif-medium"/>
                <TextView
                    android:id="@+id/tvSummativeCount"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentEnd="true"
                    android:text="0 / 40"
                    android:textSize="12sp"
                    android:textColor="#546E7A"
                    android:fontFamily="sans-serif-bold"/>
            </RelativeLayout>
            
            <ProgressBar
                android:id="@+id/pbSummative"
                style="?android:attr/progressBarStyleHorizontal"
                android:layout_width="match_parent"
                android:layout_height="8dp"
                android:progressDrawable="@drawable/custom_progress_green"
                android:max="100"
                android:progress="0"/>
        </LinearLayout>

        <!-- Descriptive Progress -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">
            
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="4dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/txt_descriptive_progress"
                    android:textSize="12sp"
                    android:textColor="#7B1FA2"
                    android:fontFamily="sans-serif-medium"/>
                <TextView
                    android:id="@+id/tvDescriptiveCount"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentEnd="true"
                    android:text="0 / 40"
                    android:textSize="12sp"
                    android:textColor="#546E7A"
                    android:fontFamily="sans-serif-bold"/>
            </RelativeLayout>
            
            <ProgressBar
                android:id="@+id/pbDescriptive"
                style="?android:attr/progressBarStyleHorizontal"
                android:layout_width="match_parent"
                android:layout_height="8dp"
                android:progressDrawable="@drawable/custom_progress_purple"
                android:max="100"
                android:progress="0"/>
        </LinearLayout>

    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
