<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginStart="10dp"
    android:layout_marginEnd="10dp"
    android:layout_marginBottom="10dp"
    app:cardCornerRadius="16dp"
    app:cardElevation="3dp"
    app:strokeWidth="0.8dp"
    app:strokeColor="?attr/colorOutlineVariant"
    app:cardBackgroundColor="?attr/colorSurface">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="8dp">

        <!-- Student Header Row -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:layout_marginBottom="6dp">

            <!-- Square Avatar Placeholder Card -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardStudentAvatar"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_alignParentStart="true"
                android:layout_centerVertical="true"
                app:cardCornerRadius="8dp"
                app:cardElevation="0dp"
                app:strokeWidth="1.5dp"
                app:strokeColor="#6C4CCF"
                app:cardBackgroundColor="#F3EEFF">

                <ImageView
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:src="@drawable/ic_person"
                    app:tint="#6C4CCF"
                    android:padding="6dp"
                    android:contentDescription="Avatar" />
            </com.google.android.material.card.MaterialCardView>

            <!-- Student Name in Marathi/Purple -->
            <TextView
                android:id="@+id/tvStudentName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_toEndOf="@id/cardStudentAvatar"
                android:layout_toStartOf="@id/btnStudentMore"
                android:layout_centerVertical="true"
                android:layout_marginStart="14dp"
                android:fontFamily="sans-serif-medium"
                android:text="@string/txt_1"
                android:textColor="#6C4CCF"
                android:textSize="17sp"
                android:textStyle="bold" />

            <!-- Horizontal 3-dot action menu in purple -->
            <ImageButton
                android:id="@+id/btnStudentMore"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@drawable/ic_more_vert"
                app:tint="#6C4CCF"
                android:padding="8dp"
                android:contentDescription="Action Menu" />
        </RelativeLayout>

        <!-- Grade Chips Row -->
        <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:scrollbars="none"
            android:layout_marginBottom="4dp">
            <LinearLayout
                android:id="@+id/layoutGradeChips"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingStart="4dp"
                android:paddingEnd="4dp" />
        </HorizontalScrollView>

        <!-- Grid summary section (visible in grid/compressed view) -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/layoutSummaryGrid"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:layout_marginBottom="4dp"
            app:cardCornerRadius="10dp"
            app:cardElevation="0dp"
            app:strokeWidth="0.8dp"
            app:strokeColor="?attr/colorOutlineVariant"
            app:cardBackgroundColor="?attr/colorSurface"
            android:visibility="gone">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:baselineAligned="false">

                <!-- FET Column -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:orientation="vertical">
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="FET"
                        android:gravity="center"
                        android:textColor="#78909C"
                        android:textSize="10sp"
                        android:textStyle="bold"
                        android:padding="3dp"
                        android:background="@drawable/bg_table_cell" />
                    <TextView
                        android:id="@+id/tvSummaryFETObtained"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="0"
                        android:gravity="center"
                        android:textColor="#37474F"
                        android:textSize="11sp"
                        android:padding="4dp"
                        android:background="@drawable/bg_table_cell" />
                    <TextView
                        android:id="@+id/tvSummaryFETMax"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="0"
                        android:gravity="center"
                        android:textColor="#78909C"
                        android:textSize="10sp"
                        android:padding="3dp"
                        android:background="@drawable/bg_table_cell" />
                </LinearLayout>

                <!-- SET Column -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:orientation="vertical">
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="SET"
                        android:gravity="center"
                        android:textColor="#78909C"
                        android:textSize="10sp"
                        android:textStyle="bold"
                        android:padding="3dp"
                        android:background="@drawable/bg_table_cell" />
                    <TextView
                        android:id="@+id/tvSummarySETObtained"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="0"
                        android:gravity="center"
                        android:textColor="#37474F"
                        android:textSize="11sp"
                        android:padding="4dp"
                        android:background="@drawable/bg_table_cell" />
                    <TextView
                        android:id="@+id/tvSummarySETMax"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="0"
                        android:gravity="center"
                        android:textColor="#78909C"
                        android:textSize="10sp"
                        android:padding="3dp"
                        android:background="@drawable/bg_table_cell" />
                </LinearLayout>

                <!-- TET Column -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1.1"
                    android:orientation="vertical">
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="TET"
                        android:gravity="center"
                        android:textColor="#78909C"
                        android:textSize="10sp"
                        android:textStyle="bold"
                        android:padding="3dp"
                        android:background="@drawable/bg_table_cell" />
                    <TextView
                        android:id="@+id/tvSummaryTETObtained"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="0"
                        android:gravity="center"
                        android:textColor="#6C4CCF"
                        android:textStyle="bold"
                        android:textSize="11sp"
                        android:padding="4dp"
                        android:background="@drawable/bg_table_cell" />
                    <TextView
                        android:id="@+id/tvSummaryTETMax"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="0"
                        android:gravity="center"
                        android:textColor="#78909C"
                        android:textSize="10sp"
                        android:padding="3dp"
                        android:background="@drawable/bg_table_cell" />
                </LinearLayout>

                <!-- GRD Column -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:orientation="vertical">
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="GRD"
                        android:gravity="center"
                        android:textColor="?attr/colorSurface"
                        android:textSize="10sp"
                        android:textStyle="bold"
                        android:padding="3dp"
                        android:background="#212121" />
                    <TextView
                        android:id="@+id/tvSummaryGrade"
                        android:layout_width="match_parent"
                        android:layout_height="0dp"
                        android:layout_weight="1"
                        android:text="—"
                        android:gravity="center"
                        android:textColor="?attr/colorSurface"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:background="#90A4AE" />
                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Subject Cards Section: Horizontal Scrollable List -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvSubjectsHorizontal"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:scrollbars="none"
            android:overScrollMode="never"
            android:paddingStart="4dp"
            android:paddingEnd="4dp"
            android:clipToPadding="false" />

    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
