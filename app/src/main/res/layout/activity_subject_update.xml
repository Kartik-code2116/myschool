<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#ECEDEF"
    android:fitsSystemWindows="true">

    <!-- Top White Header Bar -->
    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/llHeaderBar"
        android:layout_width="match_parent"
        android:layout_height="72dp"
        android:background="#FFFFFF"
        app:navigationIcon="@drawable/ic_close"
        app:navigationIconTint="#5A4FCF"
        app:title="@string/txt_update_subject"
        app:titleTextColor="#2E2E2E"
        app:titleCentered="false"
        app:elevation="2dp"/>

    <!-- Scrollable Form Container -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_above="@+id/llBottomButtons"
        android:layout_below="@+id/llHeaderBar"
        android:fillViewport="true"
        android:paddingHorizontal="16dp"
        android:paddingTop="12dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Row 1: Two Column Layout (Subject Code & Teacher Id) -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="12dp">

                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/tilSubjectCode"
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginEnd="6dp"
                    android:hint="@string/txt_subject_code"
                    app:boxCornerRadiusBottomEnd="12dp"
                    app:boxCornerRadiusBottomStart="12dp"
                    app:boxCornerRadiusTopEnd="12dp"
                    app:boxCornerRadiusTopStart="12dp"
                    app:boxStrokeColor="#8E8E8E"
                    app:hintTextColor="#8E8E8E">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etSubjectCode"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="text"
                        android:text="1"
                        android:textColor="#222222"
                        android:textSize="16sp" />
                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/tilTeacherId"
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="6dp"
                    android:hint="@string/txt_teacher_id"
                    app:boxCornerRadiusBottomEnd="12dp"
                    app:boxCornerRadiusBottomStart="12dp"
                    app:boxCornerRadiusTopEnd="12dp"
                    app:boxCornerRadiusTopStart="12dp"
                    app:boxStrokeColor="#8E8E8E"
                    app:hintTextColor="#8E8E8E">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etTeacherId"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="text"
                        android:text="@string/txt_null"
                        android:textColor="#222222"
                        android:textSize="16sp" />
                </com.google.android.material.textfield.TextInputLayout>
            </LinearLayout>

            <!-- Row 2: Two Column Layout (Formative & Summative Evaluation) -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="12dp">

                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/tilFormativeEval"
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginEnd="6dp"
                    android:hint="@string/txt_formative_evaluation"
                    app:boxCornerRadiusBottomEnd="12dp"
                    app:boxCornerRadiusBottomStart="12dp"
                    app:boxCornerRadiusTopEnd="12dp"
                    app:boxCornerRadiusTopStart="12dp"
                    app:boxStrokeColor="#8E8E8E"
                    app:hintTextColor="#8E8E8E">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etFormativeEval"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="number"
                        android:text="70"
                        android:textColor="#222222"
                        android:textSize="16sp" />
                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/tilSummativeEval"
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="6dp"
                    android:hint="@string/txt_summative_evaluation"
                    app:boxCornerRadiusBottomEnd="12dp"
                    app:boxCornerRadiusBottomStart="12dp"
                    app:boxCornerRadiusTopEnd="12dp"
                    app:boxCornerRadiusTopStart="12dp"
                    app:boxStrokeColor="#8E8E8E"
                    app:hintTextColor="#8E8E8E">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etSummativeEval"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="number"
                        android:text="30"
                        android:textColor="#222222"
                        android:textSize="16sp" />
                </com.google.android.material.textfield.TextInputLayout>
            </LinearLayout>

            <!-- Name of Subject (Regular) -->
            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/tilSubjectNameRegular"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:hint="@string/txt_name_of_subject_regular"
                app:boxCornerRadiusBottomEnd="12dp"
                app:boxCornerRadiusBottomStart="12dp"
                app:boxCornerRadiusTopEnd="12dp"
                app:boxCornerRadiusTopStart="12dp"
                app:boxStrokeColor="#8E8E8E"
                app:hintTextColor="#8E8E8E">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etSubjectNameRegular"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="text"
                    android:text="@string/txt_marathi"
                    android:textColor="#222222"
                    android:textSize="16sp" />
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Name of Subject (Short) -->
            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/tilSubjectNameShort"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:hint="@string/txt_name_of_subject_short"
                app:boxCornerRadiusBottomEnd="12dp"
                app:boxCornerRadiusBottomStart="12dp"
                app:boxCornerRadiusTopEnd="12dp"
                app:boxCornerRadiusTopStart="12dp"
                app:boxStrokeColor="#8E8E8E"
                app:hintTextColor="#8E8E8E">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etSubjectNameShort"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="text"
                    android:text="@string/txt_marathi"
                    android:textColor="#222222"
                    android:textSize="16sp" />
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Name of Subject (Long) -->
            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/tilSubjectNameLong"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:hint="@string/txt_name_of_subject_long"
                app:boxCornerRadiusBottomEnd="12dp"
                app:boxCornerRadiusBottomStart="12dp"
                app:boxCornerRadiusTopEnd="12dp"
                app:boxCornerRadiusTopStart="12dp"
                app:boxStrokeColor="#8E8E8E"
                app:hintTextColor="#8E8E8E">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etSubjectNameLong"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="text"
                    android:text="@string/txt_marathi"
                    android:textColor="#222222"
                    android:textSize="16sp" />
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Linked Dropdown Notes -->
            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/tilDropdownNotes"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:hint="@string/txt_linked_dropdown_notes"
                app:boxCornerRadiusBottomEnd="12dp"
                app:boxCornerRadiusBottomStart="12dp"
                app:boxCornerRadiusTopEnd="12dp"
                app:boxCornerRadiusTopStart="12dp"
                app:boxStrokeColor="#8E8E8E"
                app:hintTextColor="#8E8E8E">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etDropdownNotes"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="text"
                    android:text="@string/txt_i_1"
                    android:textColor="#222222"
                    android:textSize="16sp" />
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Dropdown Note Medium -->
            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/tilDropdownNoteMedium"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                android:hint="@string/txt_dropdown_note_medium"
                app:boxCornerRadiusBottomEnd="12dp"
                app:boxCornerRadiusBottomStart="12dp"
                app:boxCornerRadiusTopEnd="12dp"
                app:boxCornerRadiusTopStart="12dp"
                app:boxStrokeColor="#8E8E8E"
                app:hintTextColor="#8E8E8E">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etDropdownNoteMedium"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="text"
                    android:text="1"
                    android:textColor="#222222"
                    android:textSize="16sp" />
            </com.google.android.material.textfield.TextInputLayout>

        </LinearLayout>
    </ScrollView>

    <!-- Bottom Buttons Section -->
    <LinearLayout
        android:id="@+id/llBottomButtons"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:background="#ECEDEF"
        android:orientation="horizontal"
        android:paddingHorizontal="16dp"
        android:paddingVertical="12dp">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnCancel"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="0dp"
            android:layout_height="50dp"
            android:layout_weight="1"
            android:layout_marginEnd="6dp"
            android:text="@string/txt_cancel"
            android:textColor="#5A43C2"
            app:backgroundTint="#FFFFFF"
            app:cornerRadius="10dp"
            app:strokeColor="#5A43C2"
            app:strokeWidth="1dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnClear"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="0dp"
            android:layout_height="50dp"
            android:layout_weight="1"
            android:layout_marginHorizontal="6dp"
            android:text="@string/txt_clear"
            android:textColor="#5A43C2"
            app:backgroundTint="#FFFFFF"
            app:cornerRadius="10dp"
            app:strokeColor="#5A43C2"
            app:strokeWidth="1dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnUpdate"
            android:layout_width="0dp"
            android:layout_height="50dp"
            android:layout_weight="1.2"
            android:layout_marginStart="6dp"
            android:text="@string/txt_update"
            android:textColor="#FFFFFF"
            app:backgroundTint="#5A43C2"
            app:cornerRadius="25dp" />
    </LinearLayout>

</RelativeLayout>
