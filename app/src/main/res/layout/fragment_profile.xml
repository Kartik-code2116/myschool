<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background">

    <androidx.core.widget.NestedScrollView
        android:id="@+id/scrollProfile"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:fillViewport="true">

        <LinearLayout
            android:id="@+id/profileRoot"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp"
            android:paddingBottom="80dp">

            <!-- Teacher Info Card -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardProfileInfo"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="#FFFFFF"
                app:cardCornerRadius="24dp"
                app:cardElevation="2dp"
                app:strokeWidth="0dp">

                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="20dp">

                    <ImageButton
                        android:id="@+id/btnEditProfile"
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:layout_gravity="top|end"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        android:contentDescription="@string/edit_profile"
                        android:src="@drawable/ic_edit_pencil"
                        app:tint="#5A4FCF"/>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <!-- Compact view after save -->
                        <LinearLayout
                            android:id="@+id/layoutProfileView"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical">

                            <!-- Horizontal Profile Header -->
                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="horizontal"
                                android:gravity="center_vertical">

                                <!-- Teacher Round Avatar -->
                                <com.google.android.material.card.MaterialCardView
                                    android:layout_width="64dp"
                                    android:layout_height="64dp"
                                    app:cardCornerRadius="32dp"
                                    app:cardElevation="0dp"
                                    app:strokeColor="#8BC34A"
                                    app:strokeWidth="2.5dp"
                                    app:cardBackgroundColor="#FFFFFF">

                                    <ImageView
                                        android:layout_width="match_parent"
                                        android:layout_height="match_parent"
                                        android:src="@drawable/ic_person"
                                        android:padding="12dp"
                                        app:tint="#8BC34A"
                                        android:contentDescription="Teacher Avatar"/>
                                </com.google.android.material.card.MaterialCardView>

                                <!-- Teacher Name & Email block -->
                                <LinearLayout
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:orientation="vertical"
                                    android:layout_marginStart="16dp"
                                    android:layout_marginEnd="24dp">

                                    <TextView
                                        android:id="@+id/tvSummaryName"
                                        android:layout_width="match_parent"
                                        android:layout_height="wrap_content"
                                        android:fontFamily="sans-serif-medium"
                                        android:textColor="#2E2E2E"
                                        android:textSize="20sp"
                                        android:textStyle="bold"/>

                                    <TextView
                                        android:id="@+id/tvProfileEmail"
                                        android:layout_width="match_parent"
                                        android:layout_height="wrap_content"
                                        android:layout_marginTop="2dp"
                                        android:textColor="#757575"
                                        android:textSize="13sp"
                                        android:fontFamily="sans-serif"/>
                                </LinearLayout>
                            </LinearLayout>

                            <View
                                android:layout_width="match_parent"
                                android:layout_height="1dp"
                                android:background="#ECEFF1"
                                android:layout_marginTop="16dp"
                                android:layout_marginBottom="16dp"/>

                            <!-- Two Column Info Grid -->
                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="horizontal"
                                android:weightSum="2">

                                <!-- Phone details -->
                                <LinearLayout
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:orientation="vertical">

                                    <TextView
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text="@string/txt_phone_number"
                                        android:textColor="#757575"
                                        android:textSize="11sp"
                                        android:fontFamily="sans-serif-medium"/>

                                    <TextView
                                        android:id="@+id/tvSummaryPhone"
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:layout_marginTop="4dp"
                                        android:textColor="#2E2E2E"
                                        android:textSize="14sp"
                                        android:fontFamily="sans-serif-medium"/>
                                </LinearLayout>

                                <!-- UDISE details -->
                                <LinearLayout
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:orientation="vertical">

                                    <TextView
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text="@string/txt_school_udise_code"
                                        android:textColor="#757575"
                                        android:textSize="11sp"
                                        android:fontFamily="sans-serif-medium"/>

                                    <TextView
                                        android:id="@+id/tvSummaryUdise"
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:layout_marginTop="4dp"
                                        android:textColor="#2E2E2E"
                                        android:textSize="14sp"
                                        android:fontFamily="sans-serif-medium"/>
                                </LinearLayout>
                            </LinearLayout>
                        </LinearLayout>

                        <!-- Edit form -->
                        <LinearLayout
                            android:id="@+id/layoutProfileEdit"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:visibility="gone">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:fontFamily="sans-serif-medium"
                                android:text="@string/txt_edit_profile_details"
                                android:textColor="#5A4FCF"
                                android:textSize="16sp"
                                android:layout_marginBottom="12dp"/>

                            <com.google.android.material.textfield.TextInputLayout
                                android:id="@+id/tilName"
                                style="@style/Widget.EduReport.TextInputLayout"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:hint="@string/label_name_field">

                                <com.google.android.material.textfield.TextInputEditText
                                    android:id="@+id/etFullName"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:inputType="textPersonName"
                                    android:singleLine="true"/>
                            </com.google.android.material.textfield.TextInputLayout>

                            <com.google.android.material.textfield.TextInputLayout
                                android:id="@+id/tilPhone"
                                style="@style/Widget.EduReport.TextInputLayout"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="8dp"
                                android:hint="@string/label_phone">

                                <com.google.android.material.textfield.TextInputEditText
                                    android:id="@+id/etPhone"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:inputType="phone"
                                    android:singleLine="true"/>
                            </com.google.android.material.textfield.TextInputLayout>

                            <com.google.android.material.textfield.TextInputLayout
                                android:id="@+id/tilUdise"
                                style="@style/Widget.EduReport.TextInputLayout"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="8dp"
                                android:hint="@string/label_udise_short">

                                <com.google.android.material.textfield.TextInputEditText
                                    android:id="@+id/etUdise"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:inputType="number"
                                    android:singleLine="true"/>
                            </com.google.android.material.textfield.TextInputLayout>

                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/btnSaveProfile"
                                style="@style/Widget.EduReport.Button"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="12dp"
                                android:text="@string/save_changes"
                                app:backgroundTint="#5A4FCF"/>
                        </LinearLayout>
                    </LinearLayout>
                </FrameLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Classes Section Title -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:fontFamily="sans-serif-medium"
                android:text="@string/your_classes_std"
                android:textColor="@color/on_surface"
                android:textSize="15sp"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="@string/profile_class_hint"
                android:textColor="@color/on_surface_variant"
                android:textSize="12sp"/>

            <!-- Active Class Detail Banner -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardActiveClassDetail"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:visibility="gone"
                app:cardBackgroundColor="#5A4FCF"
                app:cardCornerRadius="24dp"
                app:cardElevation="4dp"
                app:strokeWidth="0dp">

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="20dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:layout_toStartOf="@+id/ivActiveIcon">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="sans-serif-black"
                            android:text="⭐ ACTIVE CLASS (NOW SELECTED)"
                            android:textColor="#D1C4E9"
                            android:textSize="11sp"
                            android:letterSpacing="0.08"/>

                        <TextView
                            android:id="@+id/tvActiveClassTitle"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:fontFamily="sans-serif-black"
                            android:textColor="#FFFFFF"
                            android:textSize="22sp"
                            android:textStyle="bold"/>

                        <TextView
                            android:id="@+id/tvActiveClassStudents"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="6dp"
                            android:textColor="#E0F2F1"
                            android:textSize="14sp"
                            android:fontFamily="sans-serif-medium"/>

                        <TextView
                            android:id="@+id/tvActiveClassDivisions"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:textColor="#D1C4E9"
                            android:textSize="13sp"/>

                        <TextView
                            android:id="@+id/tvActiveClassExtra"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="6dp"
                            android:textColor="#D1C4E9"
                            android:alpha="0.9"
                            android:textSize="12sp"/>
                    </LinearLayout>

                    <ImageView
                        android:id="@+id/ivActiveIcon"
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:layout_alignParentEnd="true"
                        android:layout_centerVertical="true"
                        android:src="@drawable/ic_check_circle"
                        app:tint="#FFFFFF"
                        android:alpha="0.8"
                        android:contentDescription="Active Class"/>
                </RelativeLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- RecyclerView Class List -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvProfileClasses"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:nestedScrollingEnabled="false"/>

            <TextView
                android:id="@+id/tvNoClasses"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:gravity="center"
                android:text="@string/profile_no_classes"
                android:textColor="@color/on_surface_variant"
                android:textSize="13sp"
                android:visibility="gone"/>

            <!-- Logout Button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnLogout"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:minHeight="56dp"
                android:text="@string/logout"
                android:textColor="@color/error"
                app:strokeColor="@color/error"
                app:strokeWidth="2dp"
                app:cornerRadius="12dp"/>
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- FAB: Promote Students -->
    <com.google.android.material.floatingactionbutton.ExtendedFloatingActionButton
        android:id="@+id/fabPromoteStudents"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|end"
        android:layout_marginEnd="16dp"
        android:layout_marginBottom="24dp"
        android:text="Promote Students"
        app:icon="@drawable/ic_students"
        app:backgroundTint="#5A4FCF"
        android:textColor="@color/white"
        app:iconTint="@color/white"/>

    <!-- FAB: Add Class -->
    <com.google.android.material.floatingactionbutton.ExtendedFloatingActionButton
        android:id="@+id/fabAddClass"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|end"
        android:layout_marginEnd="16dp"
        android:layout_marginBottom="92dp"
        android:text="@string/txt_add_class"
        app:icon="@drawable/ic_add_circle"
        app:backgroundTint="@color/primary"
        android:textColor="@color/white"
        app:iconTint="@color/white"/>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
