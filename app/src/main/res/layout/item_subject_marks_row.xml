<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent" android:layout_height="50dp"
    android:orientation="horizontal" android:gravity="center_vertical"
    android:paddingStart="12dp" android:paddingEnd="12dp">
    <TextView android:id="@+id/tvSubjectName"
        android:layout_width="0dp" android:layout_height="wrap_content"
        android:layout_weight="3" android:text="Mathematics"
        android:textSize="13sp" android:textColor="@color/on_surface"/>
    <TextView android:id="@+id/tvMaxMarks"
        android:layout_width="0dp" android:layout_height="wrap_content"
        android:layout_weight="1" android:text="100"
        android:textSize="13sp" android:textColor="@color/on_surface_variant" android:gravity="center"/>
    <com.google.android.material.textfield.TextInputEditText android:id="@+id/etObtainedMarks"
        android:layout_width="0dp" android:layout_height="38dp"
        android:layout_weight="1" android:inputType="numberDecimal"
        android:singleLine="true" android:gravity="center"
        android:textSize="14sp" android:fontFamily="sans-serif-medium"
        android:textColor="@color/primary" android:hint="--"
        android:background="@drawable/bg_surface_rounded"
        android:textColorHint="@color/on_surface_variant" android:padding="4dp"/>
</LinearLayout>
