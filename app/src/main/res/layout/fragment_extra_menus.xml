<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F7FA">

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:paddingBottom="24dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Context Header Card -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardBackgroundColor="@color/surface"
                app:cardCornerRadius="16dp"
                app:cardElevation="2dp"
                app:strokeWidth="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:id="@+id/tvExtraContextTitle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="sans-serif-medium"
                        android:text="@string/txt_student_level_administration"
                        android:textColor="@color/primary"
                        android:textSize="16sp" />

                    <TextView
                        android:id="@+id/tvExtraContextSubtitle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:fontFamily="sans-serif"
                        android:text="@string/txt_year_2026_27_class_1_div_a"
                        android:textColor="@color/on_surface_variant"
                        android:textSize="13sp" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Unified Content Card -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="@color/surface"
                app:cardCornerRadius="16dp"
                app:cardElevation="3dp"
                app:strokeWidth="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <!-- 1. SCHOOL INFORMATION -->
                    <LinearLayout
                        android:id="@+id/llSchoolInfo"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:visibility="gone">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/txt_school_details"
                            android:textSize="18sp"
                            android:textColor="@color/on_surface"
                            android:fontFamily="sans-serif-medium"
                            android:layout_marginBottom="16dp"/>

                        <TextView android:id="@+id/tvSchoolInfoName" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="@string/fmt_school_name" android:textSize="14sp" android:textColor="#333333" android:layout_marginBottom="8dp"/>
                        <TextView android:id="@+id/tvSchoolInfoUdise" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="@string/fmt_school_udise" android:textSize="14sp" android:textColor="#333333" android:layout_marginBottom="8dp"/>
                        <TextView android:id="@+id/tvSchoolInfoBoard" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="@string/fmt_school_board" android:textSize="14sp" android:textColor="#333333" android:layout_marginBottom="8dp"/>
                        <TextView android:id="@+id/tvSchoolInfoAddress" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="@string/fmt_school_address" android:textSize="14sp" android:textColor="#333333" android:layout_marginBottom="16dp"/>
                        
                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnEditSchoolInfo"
                            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="end"
                            android:text="@string/btn_edit_school"
                            android:layout_marginBottom="16dp"/>

                        <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#E0E0E0" android:layout_marginBottom="16dp"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/txt_student_stats_summary" android:textSize="14sp" android:textColor="@color/primary" android:fontFamily="sans-serif-medium" android:layout_marginBottom="8dp"/>
                        <TextView android:id="@+id/tvSchoolInfoTotalStudents" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="@string/txt_total_enrolled_250_students" android:textSize="13sp" android:textColor="#666666"/>
                    </LinearLayout>

                    <!-- 2. GENDER -->
                    <LinearLayout
                        android:id="@+id/llGender"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:visibility="gone">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/txt_gender_distribution"
                            android:textSize="18sp"
                            android:textColor="@color/on_surface"
                            android:fontFamily="sans-serif-medium"
                            android:layout_marginBottom="16dp"/>

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:layout_marginBottom="20dp">

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:gravity="center"
                                android:orientation="vertical">
                                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/txt_boys" android:textSize="11sp" android:textColor="#1E88E5" android:fontFamily="sans-serif-medium"/>
                                <TextView android:id="@+id/tvGenderBoysCount" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="15" android:textSize="36sp" android:textColor="#1E88E5" android:fontFamily="sans-serif-thin"/>
                            </LinearLayout>

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:gravity="center"
                                android:orientation="vertical">
                                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/txt_girls" android:textSize="11sp" android:textColor="#EC407A" android:fontFamily="sans-serif-medium"/>
                                <TextView android:id="@+id/tvGenderGirlsCount" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="18" android:textSize="36sp" android:textColor="#EC407A" android:fontFamily="sans-serif-thin"/>
                            </LinearLayout>
                        </LinearLayout>

                        <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#E0E0E0" android:layout_marginBottom="16dp"/>
                        <TextView android:id="@+id/tvGenderRatio" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="@string/txt_active_class_gender_ratio_45_4" android:textSize="13sp" android:textColor="#666666" android:gravity="center"/>
                    </LinearLayout>

                    <!-- 3. CAST CATEGORY -->
                    <LinearLayout
                        android:id="@+id/llCastCategory"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:visibility="gone">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/txt_cast_categories"
                            android:textSize="18sp"
                            android:textColor="@color/on_surface"
                            android:fontFamily="sans-serif-medium"
                            android:layout_marginBottom="16dp"/>

                        <TextView android:id="@+id/tvCastGeneral" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="@string/txt_general_open_10_students" android:textSize="14sp" android:textColor="#333333" android:layout_marginBottom="8dp"/>
                        <TextView android:id="@+id/tvCastObc" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="@string/txt_obc_category_12_students" android:textSize="14sp" android:textColor="#333333" android:layout_marginBottom="8dp"/>
                        <TextView android:id="@+id/tvCastSc" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="@string/txt_sc_category_6_students" android:textSize="14sp" android:textColor="#333333" android:layout_marginBottom="8dp"/>
                        <TextView android:id="@+id/tvCastSt" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="@string/txt_st_category_5_students" android:textSize="14sp" android:textColor="#333333" android:layout_marginBottom="16dp"/>

                        <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#E0E0E0" android:layout_marginBottom="16dp"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/txt_category_distribution_is_calcu" android:textSize="12sp" android:textColor="#888888"/>
                    </LinearLayout>

                    <!-- 4. CLASS TEACHER -->
                    <LinearLayout
                        android:id="@+id/llClassTeacher"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:visibility="gone">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/txt_assigned_teachers"
                            android:textSize="18sp"
                            android:textColor="@color/on_surface"
                            android:fontFamily="sans-serif-medium"
                            android:layout_marginBottom="16dp"/>

                        <TextView android:id="@+id/tvTeacherInfoPrimary" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="@string/txt_class_teacher_mrs_sharma" android:textSize="14sp" android:textColor="#333333" android:layout_marginBottom="8dp" android:fontFamily="sans-serif-medium"/>
                        <TextView android:id="@+id/tvTeacherInfoAsst" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="@string/txt_assistant_teacher_mr_patil" android:textSize="14sp" android:textColor="#333333" android:layout_marginBottom="16dp"/>

                        <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#E0E0E0" android:layout_marginBottom="16dp"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/txt_contact_information" android:textSize="14sp" android:textColor="@color/primary" android:fontFamily="sans-serif-medium" android:layout_marginBottom="8dp"/>
                        <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Primary Email: teacher@school.edu\nPhone: +91 9876543210" android:textSize="13sp" android:textColor="#666666"/>
                    </LinearLayout>

                    <!-- 5. CLASSES -->
                    <LinearLayout
                        android:id="@+id/llClasses"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:visibility="gone">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/txt_classes_listing"
                            android:textSize="18sp"
                            android:textColor="@color/on_surface"
                            android:fontFamily="sans-serif-medium"
                            android:layout_marginBottom="16dp"/>

                        <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="@string/txt_standard_1_1_division_33_stude" android:textSize="14sp" android:textColor="#333333" android:layout_marginBottom="8dp"/>
                        <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="@string/txt_standard_2_1_division_28_stude" android:textSize="14sp" android:textColor="#333333" android:layout_marginBottom="8dp"/>
                        <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="@string/txt_standard_3_2_divisions_45_stud" android:textSize="14sp" android:textColor="#333333" android:layout_marginBottom="8dp"/>
                        <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="@string/txt_standard_4_1_division_30_stude" android:textSize="14sp" android:textColor="#333333" android:layout_marginBottom="16dp"/>

                        <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#E0E0E0" android:layout_marginBottom="16dp"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/txt_select_profile_tab_in_sidebar" android:textSize="12sp" android:textColor="#888888"/>
                    </LinearLayout>

                    <!-- 6. SUBJECT -->
                    <LinearLayout
                        android:id="@+id/llSubject"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:visibility="gone">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/txt_class_subjects_details"
                            android:textSize="18sp"
                            android:textColor="@color/on_surface"
                            android:fontFamily="sans-serif-medium"
                            android:layout_marginBottom="16dp"/>

                        <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="@string/txt_1_marathi_max_marks_100_fe_70" android:textSize="14sp" android:textColor="#333333" android:layout_marginBottom="8dp"/>
                        <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="@string/txt_2_hindi_max_marks_100_fe_70_se" android:textSize="14sp" android:textColor="#333333" android:layout_marginBottom="8dp"/>
                        <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="@string/txt_3_english_max_marks_100_fe_70" android:textSize="14sp" android:textColor="#333333" android:layout_marginBottom="8dp"/>
                        <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="@string/txt_4_mathematics_max_marks_100_fe" android:textSize="14sp" android:textColor="#333333" android:layout_marginBottom="16dp"/>

                        <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#E0E0E0" android:layout_marginBottom="16dp"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/txt_you_can_toggle_active_subjects" android:textSize="12sp" android:textColor="#888888"/>
                    </LinearLayout>

                    <!-- 7. DEFAULT VALUES -->
                    <LinearLayout
                        android:id="@+id/llDefaultValues"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:visibility="gone">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/txt_admission_baseline_defaults"
                            android:textSize="18sp"
                            android:textColor="@color/on_surface"
                            android:fontFamily="sans-serif-medium"
                            android:layout_marginBottom="16dp"/>

                        <com.google.android.material.textfield.TextInputLayout
                            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="12dp"
                            android:hint="@string/txt_default_medium_of_instruction"
                            app:boxCornerRadiusBottomEnd="8dp"
                            app:boxCornerRadiusBottomStart="8dp"
                            app:boxCornerRadiusTopEnd="8dp"
                            app:boxCornerRadiusTopStart="8dp">
                            <com.google.android.material.textfield.TextInputEditText
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="@string/txt_marathi" />
                        </com.google.android.material.textfield.TextInputLayout>

                        <com.google.android.material.textfield.TextInputLayout
                            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="16dp"
                            android:hint="@string/txt_default_religion_state"
                            app:boxCornerRadiusBottomEnd="8dp"
                            app:boxCornerRadiusBottomStart="8dp"
                            app:boxCornerRadiusTopEnd="8dp"
                            app:boxCornerRadiusTopStart="8dp">
                            <com.google.android.material.textfield.TextInputEditText
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="@string/txt_maharashtra" />
                        </com.google.android.material.textfield.TextInputLayout>

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnSaveDefaults"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="@string/txt_save_default_settings"
                            app:backgroundTint="@color/primary"
                            app:cornerRadius="8dp" />
                    </LinearLayout>

                    <!-- 8. WORKING DAYS -->
                    <LinearLayout
                        android:id="@+id/llWorkingDays"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:visibility="gone">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/txt_working_days_log"
                            android:textSize="18sp"
                            android:textColor="@color/on_surface"
                            android:fontFamily="sans-serif-medium"
                            android:layout_marginBottom="16dp"/>

                        <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="@string/txt_semester_1_total_working_days" android:textSize="14sp" android:textColor="#333333" android:layout_marginBottom="8dp"/>
                        <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="@string/txt_semester_2_total_working_days" android:textSize="14sp" android:textColor="#333333" android:layout_marginBottom="8dp"/>
                        <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="@string/txt_assigned_holidays_45_days" android:textSize="14sp" android:textColor="#333333" android:layout_marginBottom="16dp"/>

                        <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#E0E0E0" android:layout_marginBottom="16dp"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/txt_calculates_average_student_att" android:textSize="12sp" android:textColor="#888888"/>
                    </LinearLayout>

                    <!-- 9. HE/SHE ITEMS -->
                    <LinearLayout
                        android:id="@+id/llHeSheItems"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:visibility="gone">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/txt_he_she_comment_helper"
                            android:textSize="18sp"
                            android:textColor="@color/on_surface"
                            android:fontFamily="sans-serif-medium"
                            android:layout_marginBottom="16dp"/>

                        <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="@string/txt_male_student_comment_descripto" android:textSize="14sp" android:textColor="#333333" android:layout_marginBottom="8dp"/>
                        <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="@string/txt_female_student_comment_descrip" android:textSize="14sp" android:textColor="#333333" android:layout_marginBottom="16dp"/>

                        <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#E0E0E0" android:layout_marginBottom="16dp"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/txt_comment_descriptors_are_applie" android:textSize="12sp" android:textColor="#888888"/>
                    </LinearLayout>

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
