<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#EFEFEF"
    android:orientation="vertical">

    <!-- Header Section Below AppBar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="12dp"
        android:background="#EFEFEF">

        <TextView
            android:id="@+id/tvReportPrintingYear"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/txt_year_2026_27"
            android:textColor="#333333"
            android:textSize="16sp"
            android:textStyle="bold" />

        <!-- Watch Animation Button -->
        <FrameLayout
            android:id="@+id/btnWatchSquare"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:layout_marginEnd="6dp"
            android:background="@drawable/bg_outlined_square_icon"
            android:padding="6dp"
            android:clickable="true"
            android:focusable="true">
            <ImageView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:src="@drawable/ic_play"
                app:tint="#37474F" />
        </FrameLayout>

        <!-- Help Outlined Icon inside outlined square -->
        <FrameLayout
            android:id="@+id/btnHelpSquare"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:background="@drawable/bg_outlined_square_icon"
            android:padding="6dp"
            android:clickable="true"
            android:focusable="true">
            <ImageView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:src="@drawable/ic_help_outline"
                app:tint="#37474F" />
        </FrameLayout>
    </LinearLayout>

    <!-- RecyclerView for stacked cards -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvReportCards"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:paddingBottom="24dp" />

</LinearLayout>
