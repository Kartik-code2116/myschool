<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="38dp"
    android:orientation="horizontal" android:gravity="center_vertical"
    android:paddingStart="10dp" android:paddingEnd="10dp"
    android:background="?attr/selectableItemBackground">
    <TextView android:id="@+id/tvRowSubject"
        android:layout_width="0dp" android:layout_height="wrap_content"
        android:layout_weight="3" android:text="@string/txt_mathematics"
        android:textSize="12sp" android:textColor="#FF212121"/>
    <TextView android:id="@+id/tvRowMax"
        android:layout_width="0dp" android:layout_height="wrap_content"
        android:layout_weight="1" android:text="100"
        android:textSize="12sp" android:textColor="#FF616161" android:gravity="center"/>
    <TextView android:id="@+id/tvRowObtained"
        android:layout_width="0dp" android:layout_height="wrap_content"
        android:layout_weight="1" android:text="87"
        android:textSize="12sp" android:fontFamily="sans-serif-medium"
        android:textColor="#FF212121" android:gravity="center"/>
    <TextView android:id="@+id/tvRowGrade"
        android:layout_width="0dp" android:layout_height="wrap_content"
        android:layout_weight="1" android:text="@string/txt_a"
        android:textSize="12sp" android:fontFamily="sans-serif-medium"
        android:textColor="#FF1565C0" android:gravity="center"/>
</LinearLayout>
