<?xml version="1.0" encoding="utf-8"?>
<androidx.drawerlayout.widget.DrawerLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/drawerLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true">

    <!-- ===== Main content ===== -->
    <androidx.coordinatorlayout.widget.CoordinatorLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/background">

        <com.google.android.material.appbar.AppBarLayout
            android:id="@+id/appBarLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="?attr/colorSurface"
            android:fitsSystemWindows="true"
            app:elevation="2dp">

            <androidx.appcompat.widget.Toolbar
                android:id="@+id/toolbar"
                android:layout_width="match_parent"
                android:layout_height="72dp"
                android:paddingStart="4dp"
                android:paddingEnd="8dp"
                android:background="?attr/colorSurface">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <!-- Hamburger -->
                    <ImageButton
                        android:id="@+id/btnMenu"
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:src="@drawable/ic_menu"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        android:padding="12dp"
                        app:tint="?attr/colorPrimary"
                        android:contentDescription="Open menu"/>

                    <!-- Title + subtitle -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:layout_marginStart="8dp">

                        <TextView
                            android:id="@+id/tvToolbarTitle"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/app_name"
                            android:textColor="?attr/colorOnSurface"
                            android:textSize="20sp"
                            android:fontFamily="sans-serif-black"
                            android:textStyle="bold"/>

                        <TextView
                            android:id="@+id/tvToolbarSubtitle"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/home_greeting"
                            android:textColor="?attr/colorOnSurface"
                            android:textSize="11sp"
                            android:alpha="0.8"/>
                    </LinearLayout>

                    <!-- Subjects custom toolbar icons -->
                    <ImageButton
                        android:id="@+id/btnToolbarNotifications"
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:src="@drawable/ic_notifications"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        app:tint="?attr/colorPrimary"
                        android:padding="8dp"
                        android:visibility="gone"
                        android:contentDescription="Notifications"/>

                    <!-- Help Icon -->
                    <ImageButton
                        android:id="@+id/btnToolbarHelp"
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:src="@drawable/ic_help_outline"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        app:tint="?attr/colorPrimary"
                        android:padding="8dp"
                        android:contentDescription="Help"/>

                    <!-- Add Icon -->
                    <ImageButton
                        android:id="@+id/btnToolbarAdd"
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:src="@drawable/ic_add_box"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        app:tint="?attr/colorPrimary"
                        android:padding="8dp"
                        android:visibility="gone"
                        android:contentDescription="Add"/>

                    <!-- Calc Icon -->
                    <ImageButton
                        android:id="@+id/btnToolbarCalc"
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:src="@drawable/ic_calculator"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        app:tint="?attr/colorPrimary"
                        android:padding="8dp"
                        android:visibility="gone"
                        android:contentDescription="Calculator"/>

                    <!-- Profile icon -->
                    <ImageView
                        android:id="@+id/ivProfilePic"
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:src="@drawable/ic_person"
                        android:padding="8dp"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        app:tint="?attr/colorPrimary"
                        android:visibility="gone"/>

                    <!-- Promote Students Icon -->

                    <ImageButton
                        android:id="@+id/btnToolbarMore"
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:src="@drawable/ic_more_vert"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        app:tint="?attr/colorPrimary"
                        android:padding="8dp"
                        android:visibility="gone"
                        android:contentDescription="More options"/>
                </LinearLayout>
            </androidx.appcompat.widget.Toolbar>
        </com.google.android.material.appbar.AppBarLayout>

        <!-- Fragment container -->
        <androidx.fragment.app.FragmentContainerView
            android:id="@+id/navHostFragment"
            android:name="androidx.navigation.fragment.NavHostFragment"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_marginBottom="64dp"
            app:layout_behavior="@string/appbar_scrolling_view_behavior"
            app:defaultNavHost="true"
            app:navGraph="@navigation/nav_graph"/>

        <!-- Bottom navigation -->
        <com.google.android.material.bottomnavigation.BottomNavigationView
            android:id="@+id/bottomNav"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom"
            android:background="@color/surface"
            app:elevation="8dp"
            app:labelVisibilityMode="labeled"
            app:menu="@menu/bottom_nav_menu"/>

    </androidx.coordinatorlayout.widget.CoordinatorLayout>

    <!-- ===== Navigation Drawer ===== -->
    <com.google.android.material.navigation.NavigationView
        android:id="@+id/navigationView"
        style="@style/Widget.EduReport.NavigationView"
        android:layout_width="300dp"
        android:layout_height="match_parent"
        android:layout_gravity="start"
        android:fitsSystemWindows="false"
        app:headerLayout="@layout/nav_header"
        app:menu="@menu/drawer_menu"/>

</androidx.drawerlayout.widget.DrawerLayout>
