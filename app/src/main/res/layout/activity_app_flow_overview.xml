<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/colorSurface">

    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="?attr/colorSurface"
        app:elevation="0dp">

        <androidx.appcompat.widget.Toolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            app:title="अॅप कसे वापरावे?"
            app:titleTextColor="?attr/colorPrimary" />
            <!-- Ensure ic_back exists, usually it does, or use arrow_back -->
    </com.google.android.material.appbar.AppBarLayout>

    <androidx.core.widget.NestedScrollView
        android:id="@+id/scrollView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:paddingBottom="40dp"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:id="@+id/llContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="16dp"
            android:paddingTop="16dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="MySchool अॅपचा वापर"
                android:textSize="24sp"
                android:textStyle="bold"
                android:textColor="?attr/colorPrimary"
                android:layout_marginBottom="8dp"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="नव्या युजर्ससाठी स्टेप-बाय-स्टेप मार्गदर्शिका. खालील क्रमाने काम केल्यास तुमचा शाळेचा सर्व डेटा अगदी सोप्या पद्धतीने व्यवस्थापित होईल."
                android:textSize="14sp"
                android:textColor="?attr/colorOnSurfaceVariant"
                android:layout_marginBottom="24dp"
                android:lineSpacingExtra="4dp"/>

            <!-- Step 1 -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardStep1"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="2dp"
                app:cardBackgroundColor="#F3EEFF"
                app:strokeWidth="1dp"
                app:strokeColor="?attr/colorPrimary">
                
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">
                    
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="🏫 पहिली स्टेप: वर्ग जोडणे"
                        android:textStyle="bold"
                        android:textSize="18sp"
                        android:textColor="?attr/colorPrimary"/>
                        
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:textSize="14sp"
                        android:textColor="?attr/colorOnSurface"
                        android:text="सुरुवात करण्यासाठी 'प्रोफाईल' टॅबवर जाऊन प्रथम तुमचे शैक्षणिक वर्ष, सत्र निवडा आणि तुमचा नवीन वर्ग व तुकडी (उदा. 5-A) तयार करा."/>
                        
                    <androidx.cardview.widget.CardView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        app:cardCornerRadius="12dp"
                        app:cardElevation="0dp">
                        <ImageView
                            android:id="@+id/ivStep1"
                            android:layout_width="match_parent"
                            android:layout_height="300dp"
                            android:scaleType="centerCrop"
                            android:src="@drawable/tut_img_step1"/>
                    </androidx.cardview.widget.CardView>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Step 2 -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardStep2"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="2dp"
                app:cardBackgroundColor="#E3F2FD"
                app:strokeWidth="1dp"
                app:strokeColor="#1976D2">
                
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">
                    
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="👨‍🎓 दुसरी स्टेप: विद्यार्थी जोडणे"
                        android:textStyle="bold"
                        android:textSize="18sp"
                        android:textColor="#1976D2"/>
                        
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:textSize="14sp"
                        android:textColor="?attr/colorOnSurface"
                        android:text="विद्यार्थी यादी पेजवर जाऊन नवीन विद्यार्थ्यांची नोंदणी करा. तुम्ही एका क्लिकवर एक्सेल फाईलमधून सर्व विद्यार्थी आयात (Import) करू शकता."/>
                        
                    <androidx.cardview.widget.CardView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        app:cardCornerRadius="12dp"
                        app:cardElevation="0dp">
                        <ImageView
                            android:id="@+id/ivStep2"
                            android:layout_width="match_parent"
                            android:layout_height="300dp"
                            android:scaleType="centerCrop"
                            android:src="@drawable/tut_img_step2"/>
                    </androidx.cardview.widget.CardView>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Step 3 -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardStep3"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="2dp"
                app:cardBackgroundColor="#E8F5E9"
                app:strokeWidth="1dp"
                app:strokeColor="#388E3C">
                
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">
                    
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="📅 तिसरी स्टेप: हजेरी भरणे"
                        android:textStyle="bold"
                        android:textSize="18sp"
                        android:textColor="#388E3C"/>
                        
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:textSize="14sp"
                        android:textColor="?attr/colorOnSurface"
                        android:text="विद्यार्थी जोडल्यानंतर 'मासिक हजेरी' स्क्रीनवर जाऊन प्रत्येक विद्यार्थ्याची दर महिन्याची हजर दिवसांची नोंद करा."/>
                        
                    <androidx.cardview.widget.CardView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        app:cardCornerRadius="12dp"
                        app:cardElevation="0dp">
                        <ImageView
                            android:id="@+id/ivStep3"
                            android:layout_width="match_parent"
                            android:layout_height="300dp"
                            android:scaleType="centerCrop"
                            android:src="@drawable/tut_img_step3"/>
                    </androidx.cardview.widget.CardView>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Step 4 -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardStep4"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="2dp"
                app:cardBackgroundColor="#FFF3E0"
                app:strokeWidth="1dp"
                app:strokeColor="#F57C00">
                
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">
                    
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="📝 चौथी स्टेप: आकारिक-संकलित गुण"
                        android:textStyle="bold"
                        android:textSize="18sp"
                        android:textColor="#F57C00"/>
                        
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:textSize="14sp"
                        android:textColor="?attr/colorOnSurface"
                        android:text="मूल्यमापन स्क्रीनवर प्रत्येक विषयाचे आकारिक (FA) आणि संकलित (SA) गुण भरा. गुण टाकण्यासाठी स्मार्ट कीबोर्डचा वापर करा."/>
                        
                    <androidx.cardview.widget.CardView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        app:cardCornerRadius="12dp"
                        app:cardElevation="0dp">
                        <ImageView
                            android:id="@+id/ivStep4"
                            android:layout_width="match_parent"
                            android:layout_height="300dp"
                            android:scaleType="centerCrop"
                            android:src="@drawable/tut_img_step4"/>
                    </androidx.cardview.widget.CardView>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Step 5 -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardStep5"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="2dp"
                app:cardBackgroundColor="#FCE4EC"
                app:strokeWidth="1dp"
                app:strokeColor="#C2185B">
                
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">
                    
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="💬 पाचवी स्टेप: वर्णनात्मक नोंदी"
                        android:textStyle="bold"
                        android:textSize="18sp"
                        android:textColor="#C2185B"/>
                        
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:textSize="14sp"
                        android:textColor="?attr/colorOnSurface"
                        android:text="शाळेच्या शेरे बँकेतून (Remark Bank) विद्यार्थ्यांच्या वर्तन आणि प्रगतीबाबतचे वर्णनात्मक शेरे एका क्लिकवर निवडून नोंदवा."/>
                        
                    <androidx.cardview.widget.CardView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        app:cardCornerRadius="12dp"
                        app:cardElevation="0dp">
                        <ImageView
                            android:id="@+id/ivStep5"
                            android:layout_width="match_parent"
                            android:layout_height="300dp"
                            android:scaleType="centerCrop"
                            android:src="@drawable/tut_img_step5"/>
                    </androidx.cardview.widget.CardView>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Step 6 -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardStep6"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="2dp"
                app:cardBackgroundColor="#F9FBE7"
                app:strokeWidth="1dp"
                app:strokeColor="#AFB42B">
                
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">
                    
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="🖨️ सहावी स्टेप: निकाल आणि प्रगतीपत्रक"
                        android:textStyle="bold"
                        android:textSize="18sp"
                        android:textColor="#AFB42B"/>
                        
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:textSize="14sp"
                        android:textColor="?attr/colorOnSurface"
                        android:text="सर्व माहिती भरून झाल्यावर 'अहवाल (Reports)' विभागात जा. तेथे तुम्ही सेकंदात विद्यार्थ्यांचे सुंदर प्रगतीपत्रक (PDF), रजिस्टर पृष्ठे तयार करून प्रिंट करू शकता."/>
                        
                    <androidx.cardview.widget.CardView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        app:cardCornerRadius="12dp"
                        app:cardElevation="0dp">
                        <ImageView
                            android:id="@+id/ivStep6"
                            android:layout_width="match_parent"
                            android:layout_height="300dp"
                            android:scaleType="centerCrop"
                            android:src="@drawable/tut_img_step6"/>
                    </androidx.cardview.widget.CardView>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Step 7 -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardStep7"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="2dp"
                app:cardBackgroundColor="#EFEBE9"
                app:strokeWidth="1dp"
                app:strokeColor="#5D4037">
                
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">
                    
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="💾 सातवी स्टेप: डेटा बॅकअप"
                        android:textStyle="bold"
                        android:textSize="18sp"
                        android:textColor="#5D4037"/>
                        
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:textSize="14sp"
                        android:textColor="?attr/colorOnSurface"
                        android:text="तुमचा मौल्यवान डेटा गमावू नये म्हणून सेटिंग्जमध्ये जाऊन नेहमी स्थानिक बॅकअप घ्या (Export Backup). नवा फोन घेतल्यास तुम्ही तो डेटा पुन्हा मिळवू शकता (Import Backup)."/>
                        
                    <androidx.cardview.widget.CardView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        app:cardCornerRadius="12dp"
                        app:cardElevation="0dp">
                        <ImageView
                            android:id="@+id/ivStep7"
                            android:layout_width="match_parent"
                            android:layout_height="300dp"
                            android:scaleType="centerCrop"
                            android:src="@drawable/tut_img_step7"/>
                    </androidx.cardview.widget.CardView>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnGotIt"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="16dp"
                android:text="मला समजले (Got it!)"
                android:textSize="16sp"
                app:cornerRadius="12dp"
                style="@style/Widget.EduReport.Button"/>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
