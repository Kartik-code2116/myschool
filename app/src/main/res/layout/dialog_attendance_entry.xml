<?xml version="1.0" encoding="utf-8"?>
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/dialogRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:gravity="center"
    android:background="@android:color/transparent">

    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:layout_marginStart="12dp"
        android:layout_marginEnd="12dp"
        android:layout_marginTop="40dp"
        android:layout_marginBottom="40dp"
        app:cardCornerRadius="20dp"
        app:cardElevation="12dp"
        app:cardBackgroundColor="@color/white"
        app:strokeWidth="0dp">

        <!-- Root: fills the card vertically, children stacked -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical">

            <!-- Header Bar -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="#F3EEFF"
                android:paddingStart="16dp"
                android:paddingEnd="8dp"
                android:paddingTop="14dp"
                android:paddingBottom="14dp">

                <ImageView
                    android:id="@+id/btnBack"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:src="@drawable/ic_close"
                    app:tint="#5E35B1"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:padding="4dp"
                    android:layout_marginEnd="10dp" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/tvDialogTitle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="उपस्थिती भरा"
                        android:textColor="#5E35B1"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:fontFamily="sans-serif-medium" />

                    <TextView
                        android:id="@+id/tvStudentInfo"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Student Name"
                        android:textColor="#78909C"
                        android:textSize="12sp"
                        android:maxLines="1"
                        android:ellipsize="end" />
                </LinearLayout>
            </LinearLayout>

            <!-- Column Headers -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@color/primary_container"
                android:paddingTop="6dp"
                android:paddingBottom="6dp"
                android:paddingStart="16dp"
                android:paddingEnd="16dp">

                <TextView
                    android:layout_width="90dp"
                    android:layout_height="wrap_content"
                    android:text="@string/txt_month"
                    android:textStyle="bold"
                    android:textColor="@color/primary"
                    android:textSize="11sp" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/txt_present"
                    android:textStyle="bold"
                    android:textColor="@color/primary"
                    android:textSize="11sp"
                    android:gravity="center"
                    android:layout_marginEnd="12dp" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/txt_working"
                    android:textStyle="bold"
                    android:textColor="@color/primary"
                    android:textSize="11sp"
                    android:gravity="center" />
            </LinearLayout>

            <!-- Scrollable Months — takes all remaining height -->
            <androidx.core.widget.NestedScrollView
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingHorizontal="16dp"
                    android:paddingTop="12dp"
                    android:paddingBottom="4dp">

                    <!-- SEMESTER 1 -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/txt_semester_1"
                        android:textColor="@color/primary"
                        android:textSize="11sp"
                        android:fontFamily="sans-serif-medium"
                        android:layout_marginBottom="8dp"/>

                    <!-- June -->
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginBottom="8dp">
                        <TextView android:layout_width="90dp" android:layout_height="wrap_content" android:text="@string/txt_jun" android:fontFamily="sans-serif-medium" android:textColor="@color/on_surface" android:textSize="13sp"/>
                        <EditText android:id="@+id/etJunPresent" android:layout_width="0dp" android:layout_height="38dp" android:layout_weight="1" android:hint="@string/str_empty_1" android:inputType="number" android:textSize="13sp" android:gravity="center" android:background="@drawable/bg_surface_rounded" android:textColor="@color/on_surface" android:layout_marginEnd="12dp"/>
                        <EditText android:id="@+id/etJunTotal" android:layout_width="0dp" android:layout_height="38dp" android:layout_weight="1" android:hint="@string/str_empty_2" android:inputType="number" android:textSize="13sp" android:gravity="center" android:background="@drawable/bg_surface_rounded" android:textColor="@color/on_surface"/>
                    </LinearLayout>

                    <!-- July -->
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginBottom="8dp">
                        <TextView android:layout_width="90dp" android:layout_height="wrap_content" android:text="@string/txt_jul" android:fontFamily="sans-serif-medium" android:textColor="@color/on_surface" android:textSize="13sp"/>
                        <EditText android:id="@+id/etJulPresent" android:layout_width="0dp" android:layout_height="38dp" android:layout_weight="1" android:hint="@string/str_empty_1" android:inputType="number" android:textSize="13sp" android:gravity="center" android:background="@drawable/bg_surface_rounded" android:textColor="@color/on_surface" android:layout_marginEnd="12dp"/>
                        <EditText android:id="@+id/etJulTotal" android:layout_width="0dp" android:layout_height="38dp" android:layout_weight="1" android:hint="@string/str_empty_2" android:inputType="number" android:textSize="13sp" android:gravity="center" android:background="@drawable/bg_surface_rounded" android:textColor="@color/on_surface"/>
                    </LinearLayout>

                    <!-- August -->
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginBottom="8dp">
                        <TextView android:layout_width="90dp" android:layout_height="wrap_content" android:text="@string/txt_aug" android:fontFamily="sans-serif-medium" android:textColor="@color/on_surface" android:textSize="13sp"/>
                        <EditText android:id="@+id/etAugPresent" android:layout_width="0dp" android:layout_height="38dp" android:layout_weight="1" android:hint="@string/str_empty_1" android:inputType="number" android:textSize="13sp" android:gravity="center" android:background="@drawable/bg_surface_rounded" android:textColor="@color/on_surface" android:layout_marginEnd="12dp"/>
                        <EditText android:id="@+id/etAugTotal" android:layout_width="0dp" android:layout_height="38dp" android:layout_weight="1" android:hint="@string/str_empty_2" android:inputType="number" android:textSize="13sp" android:gravity="center" android:background="@drawable/bg_surface_rounded" android:textColor="@color/on_surface"/>
                    </LinearLayout>

                    <!-- September -->
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginBottom="8dp">
                        <TextView android:layout_width="90dp" android:layout_height="wrap_content" android:text="@string/txt_sep" android:fontFamily="sans-serif-medium" android:textColor="@color/on_surface" android:textSize="13sp"/>
                        <EditText android:id="@+id/etSepPresent" android:layout_width="0dp" android:layout_height="38dp" android:layout_weight="1" android:hint="@string/str_empty_1" android:inputType="number" android:textSize="13sp" android:gravity="center" android:background="@drawable/bg_surface_rounded" android:textColor="@color/on_surface" android:layout_marginEnd="12dp"/>
                        <EditText android:id="@+id/etSepTotal" android:layout_width="0dp" android:layout_height="38dp" android:layout_weight="1" android:hint="@string/str_empty_2" android:inputType="number" android:textSize="13sp" android:gravity="center" android:background="@drawable/bg_surface_rounded" android:textColor="@color/on_surface"/>
                    </LinearLayout>

                    <!-- October -->
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginBottom="8dp">
                        <TextView android:layout_width="90dp" android:layout_height="wrap_content" android:text="@string/txt_oct" android:fontFamily="sans-serif-medium" android:textColor="@color/on_surface" android:textSize="13sp"/>
                        <EditText android:id="@+id/etOctPresent" android:layout_width="0dp" android:layout_height="38dp" android:layout_weight="1" android:hint="@string/str_empty_1" android:inputType="number" android:textSize="13sp" android:gravity="center" android:background="@drawable/bg_surface_rounded" android:textColor="@color/on_surface" android:layout_marginEnd="12dp"/>
                        <EditText android:id="@+id/etOctTotal" android:layout_width="0dp" android:layout_height="38dp" android:layout_weight="1" android:hint="@string/str_empty_2" android:inputType="number" android:textSize="13sp" android:gravity="center" android:background="@drawable/bg_surface_rounded" android:textColor="@color/on_surface"/>
                    </LinearLayout>

                    <!-- November -->
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginBottom="12dp">
                        <TextView android:layout_width="90dp" android:layout_height="wrap_content" android:text="@string/txt_nov" android:fontFamily="sans-serif-medium" android:textColor="@color/on_surface" android:textSize="13sp"/>
                        <EditText android:id="@+id/etNovPresent" android:layout_width="0dp" android:layout_height="38dp" android:layout_weight="1" android:hint="@string/str_empty_1" android:inputType="number" android:textSize="13sp" android:gravity="center" android:background="@drawable/bg_surface_rounded" android:textColor="@color/on_surface" android:layout_marginEnd="12dp"/>
                        <EditText android:id="@+id/etNovTotal" android:layout_width="0dp" android:layout_height="38dp" android:layout_weight="1" android:hint="@string/str_empty_2" android:inputType="number" android:textSize="13sp" android:gravity="center" android:background="@drawable/bg_surface_rounded" android:textColor="@color/on_surface"/>
                    </LinearLayout>

                    <!-- Divider -->
                    <View android:layout_width="match_parent" android:layout_height="1dp" android:background="@color/outline_variant" android:layout_marginBottom="12dp"/>

                    <!-- SEMESTER 2 -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/txt_semester_2"
                        android:textColor="@color/primary"
                        android:textSize="11sp"
                        android:fontFamily="sans-serif-medium"
                        android:layout_marginBottom="8dp"/>

                    <!-- December -->
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginBottom="8dp">
                        <TextView android:layout_width="90dp" android:layout_height="wrap_content" android:text="@string/txt_dec" android:fontFamily="sans-serif-medium" android:textColor="@color/on_surface" android:textSize="13sp"/>
                        <EditText android:id="@+id/etDecPresent" android:layout_width="0dp" android:layout_height="38dp" android:layout_weight="1" android:hint="@string/str_empty_1" android:inputType="number" android:textSize="13sp" android:gravity="center" android:background="@drawable/bg_surface_rounded" android:textColor="@color/on_surface" android:layout_marginEnd="12dp"/>
                        <EditText android:id="@+id/etDecTotal" android:layout_width="0dp" android:layout_height="38dp" android:layout_weight="1" android:hint="@string/str_empty_2" android:inputType="number" android:textSize="13sp" android:gravity="center" android:background="@drawable/bg_surface_rounded" android:textColor="@color/on_surface"/>
                    </LinearLayout>

                    <!-- January -->
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginBottom="8dp">
                        <TextView android:layout_width="90dp" android:layout_height="wrap_content" android:text="@string/txt_jan" android:fontFamily="sans-serif-medium" android:textColor="@color/on_surface" android:textSize="13sp"/>
                        <EditText android:id="@+id/etJanPresent" android:layout_width="0dp" android:layout_height="38dp" android:layout_weight="1" android:hint="@string/str_empty_1" android:inputType="number" android:textSize="13sp" android:gravity="center" android:background="@drawable/bg_surface_rounded" android:textColor="@color/on_surface" android:layout_marginEnd="12dp"/>
                        <EditText android:id="@+id/etJanTotal" android:layout_width="0dp" android:layout_height="38dp" android:layout_weight="1" android:hint="@string/str_empty_2" android:inputType="number" android:textSize="13sp" android:gravity="center" android:background="@drawable/bg_surface_rounded" android:textColor="@color/on_surface"/>
                    </LinearLayout>

                    <!-- February -->
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginBottom="8dp">
                        <TextView android:layout_width="90dp" android:layout_height="wrap_content" android:text="@string/txt_feb" android:fontFamily="sans-serif-medium" android:textColor="@color/on_surface" android:textSize="13sp"/>
                        <EditText android:id="@+id/etFebPresent" android:layout_width="0dp" android:layout_height="38dp" android:layout_weight="1" android:hint="@string/str_empty_1" android:inputType="number" android:textSize="13sp" android:gravity="center" android:background="@drawable/bg_surface_rounded" android:textColor="@color/on_surface" android:layout_marginEnd="12dp"/>
                        <EditText android:id="@+id/etFebTotal" android:layout_width="0dp" android:layout_height="38dp" android:layout_weight="1" android:hint="@string/str_empty_2" android:inputType="number" android:textSize="13sp" android:gravity="center" android:background="@drawable/bg_surface_rounded" android:textColor="@color/on_surface"/>
                    </LinearLayout>

                    <!-- March -->
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginBottom="8dp">
                        <TextView android:layout_width="90dp" android:layout_height="wrap_content" android:text="@string/txt_mar" android:fontFamily="sans-serif-medium" android:textColor="@color/on_surface" android:textSize="13sp"/>
                        <EditText android:id="@+id/etMarPresent" android:layout_width="0dp" android:layout_height="38dp" android:layout_weight="1" android:hint="@string/str_empty_1" android:inputType="number" android:textSize="13sp" android:gravity="center" android:background="@drawable/bg_surface_rounded" android:textColor="@color/on_surface" android:layout_marginEnd="12dp"/>
                        <EditText android:id="@+id/etMarTotal" android:layout_width="0dp" android:layout_height="38dp" android:layout_weight="1" android:hint="@string/str_empty_2" android:inputType="number" android:textSize="13sp" android:gravity="center" android:background="@drawable/bg_surface_rounded" android:textColor="@color/on_surface"/>
                    </LinearLayout>

                    <!-- April -->
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginBottom="8dp">
                        <TextView android:layout_width="90dp" android:layout_height="wrap_content" android:text="@string/txt_apr" android:fontFamily="sans-serif-medium" android:textColor="@color/on_surface" android:textSize="13sp"/>
                        <EditText android:id="@+id/etAprPresent" android:layout_width="0dp" android:layout_height="38dp" android:layout_weight="1" android:hint="@string/str_empty_1" android:inputType="number" android:textSize="13sp" android:gravity="center" android:background="@drawable/bg_surface_rounded" android:textColor="@color/on_surface" android:layout_marginEnd="12dp"/>
                        <EditText android:id="@+id/etAprTotal" android:layout_width="0dp" android:layout_height="38dp" android:layout_weight="1" android:hint="@string/str_empty_2" android:inputType="number" android:textSize="13sp" android:gravity="center" android:background="@drawable/bg_surface_rounded" android:textColor="@color/on_surface"/>
                    </LinearLayout>

                    <!-- May -->
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginBottom="8dp">
                        <TextView android:layout_width="90dp" android:layout_height="wrap_content" android:text="@string/txt_may" android:fontFamily="sans-serif-medium" android:textColor="@color/on_surface" android:textSize="13sp"/>
                        <EditText android:id="@+id/etMayPresent" android:layout_width="0dp" android:layout_height="38dp" android:layout_weight="1" android:hint="@string/str_empty_1" android:inputType="number" android:textSize="13sp" android:gravity="center" android:background="@drawable/bg_surface_rounded" android:textColor="@color/on_surface" android:layout_marginEnd="12dp"/>
                        <EditText android:id="@+id/etMayTotal" android:layout_width="0dp" android:layout_height="38dp" android:layout_weight="1" android:hint="@string/str_empty_2" android:inputType="number" android:textSize="13sp" android:gravity="center" android:background="@drawable/bg_surface_rounded" android:textColor="@color/on_surface"/>
                    </LinearLayout>

                </LinearLayout>
            </androidx.core.widget.NestedScrollView>

            <!-- Thin divider -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/outline_variant"/>

            <!-- Bottom Actions — always pinned at the bottom -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="end"
                android:paddingHorizontal="16dp"
                android:paddingVertical="10dp"
                android:background="#FAF8FF">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnCancel"
                    style="@style/Widget.Material3.Button.TextButton"
                    android:layout_width="wrap_content"
                    android:layout_height="44dp"
                    android:text="@string/txt_cancel_1" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnSave"
                    style="@style/Widget.Myschool.Button"
                    android:layout_width="wrap_content"
                    android:layout_height="44dp"
                    android:minHeight="44dp"
                    android:text="@string/txt_save"
                    app:cornerRadius="8dp"
                    android:layout_marginStart="10dp" />
            </LinearLayout>

            <!-- Progress bar -->
            <com.google.android.material.progressindicator.LinearProgressIndicator
                android:id="@+id/progress"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:indeterminate="true"
                android:visibility="gone"
                app:indicatorColor="@color/primary"
                app:trackColor="@color/primary_container" />

        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

</FrameLayout>
